<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>City of Springfield - Building Permits</title>
    <style>
        * { margin: 0; padding: 0; }
        
        body {
            font-family: Verdana, Arial, Helvetica, sans-serif;
            font-size: 11px;
            background: #eeeeee;
        }
        
        a { color: #0000ff; text-decoration: underline; }
        a:visited { color: #551a8b; }
        a:hover { color: #ff0000; }
        
        .header {
            background: #003366;
            color: #ffffff;
            padding: 15px 20px;
        }
        
        .header h1 {
            font-size: 18px;
            margin-bottom: 5px;
        }
        
        .header .subtitle {
            font-size: 11px;
            opacity: 0.9;
        }
        
        .nav-bar {
            background: #003366;
            padding: 8px 20px;
        }
        
        .nav-bar a {
            color: #ffffff;
            text-decoration: none;
            margin: 0 10px;
            font-weight: bold;
            font-size: 11px;
        }
        
        .nav-bar a:hover { color: #ffff00; }
        
        .breadcrumbs {
            font-size: 10px;
            color: #666666;
            padding: 10px 20px;
            background: #f5f5f5;
        }
        
        .breadcrumbs a { font-size: 10px; }
        
        .permit-system {
            background: #ffffff;
            padding: 20px;
            max-width: 900px;
            margin: 0 auto;
        }
        
        .permit-system h1 {
            font-size: 18px;
            color: #003366;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #003366;
        }
        
        .permit-system h2 {
            font-size: 14px;
            color: #003366;
            margin: 20px 0 10px;
        }
        
        .quick-links {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .quick-links a {
            padding: 8px 15px;
            background: #f0f0f0;
            border: 1px solid #cccccc;
            font-size: 10px;
        }
        
        .aspnet_table {
            width: 100%;
            border-collapse: collapse;
            border: 2px inset #cccccc;
            background: #ffffff;
            margin-bottom: 15px;
        }
        
        .aspnet_table td {
            padding: 6px 10px;
            border: 1px inset #dddddd;
            font-family: Verdana, Arial, sans-serif;
            font-size: 11px;
            color: #000000;
        }
        
        .aspnet_table tr:first-child td {
            background: #336699;
            color: #ffffff;
            font-weight: bold;
            text-align: center;
            border: 1px outset #6699cc;
        }
        
        .aspnet_table tr:nth-child(2) td {
            background: #f0f0f0;
            font-weight: bold;
            border: 1px inset #cccccc;
        }
        
        .aspnet_table tr:hover td { background: #ffffcc; }
        
        .aspnet_table td[colspan="3"]:first-child {
            background: #003366;
            color: #ffffff;
            font-weight: bold;
            text-align: center;
        }
        
        .aspnet_table td[colspan="2"] {
            background: #ffffcc;
            font-style: italic;
        }
        
        .aspnet_table td[rowspan] {
            background: #f5f5f5;
            font-weight: bold;
            color: #333333;
        }
        
        .status-approved { background: #d4edda !important; color: #155724; font-weight: bold; }
        .status-pending { background: #fff3cd !important; color: #856404; }
        
        .search-box {
            margin-bottom: 15px;
            padding: 10px;
            background: #f5f5f5;
            border: 1px inset #cccccc;
        }
        
        .search-box input {
            border: 1px solid #999999;
            padding: 3px;
            font-size: 11px;
        }
        
        .search-box button {
            background: #003366;
            color: #ffffff;
            border: 1px outset #004080;
            padding: 3px 10px;
;
                       cursor: pointer font-size: 11px;
        }
        
        .page-numbers {
            text-align: center;
            margin-top: 15px;
            font-size: 10px;
        }
        
        .page-numbers a { margin: 0 3px; }
        .page-numbers span { font-weight: bold; color: #003366; }
        
        .print-button {
            background: #cccccc;
            border: 1px outset #999999;
            padding: 5px 15px;
            cursor: pointer;
            font-size: 11px;
        }
        
        .footer {
            margin-top: 20px;
            padding-top: 10px;
            border-top: 1px solid #cccccc;
            text-align: center;
            color: #666666;
            font-size: 10px;
            background: #f5f5f5;
            padding: 15px;
        }
        
        .contact-info {
            background: #f0f8ff;
            padding: 15px;
            margin: 20px 0;
            border: 1px solid #cccccc;
        }
        
        .contact-info strong {
            color: #003366;
        }
        
        .forms-section {
            margin-top: 25px;
        }
        
        .forms-section ul {
            list-style: none;
        }
        
        .forms-section li {
            padding: 8px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .forms-section a {
            font-size: 11px;
        }
        
        .info-box {
            background: #fffbe6;
            border: 1px solid #ffe58f;
            padding: 10px;
            margin: 15px 0;
            font-size: 10px;
        }
    </style>
</head>
