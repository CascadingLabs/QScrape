                        <button class="secondary">Contact</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <footer>
        <p>&copy; 2026 HomeScout. All rights reserved.</p>
        <p>
            <a href="#">About</a>
            <a href="#">Careers</a>
            <a href="#">Privacy</a>
