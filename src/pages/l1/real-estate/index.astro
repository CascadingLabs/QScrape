                </select>
                <select>
                    <option>Beds + Baths</option>
                    <option>1+ bed, 1+ bath</option>
                    <option>2+ bed, 1+ bath</option>
                    <option>3+ bed, 2+ bath</option>
                    <option>4+ bed, 3+ bath</option>
                </select>
                <button>Search</button>
            </div>
            <div class="quick-filters">
                <button class="active">Houses</button>
                <button>Condos</button>
                <button>Townhomes</button>
                <button>Land</button>
                <button>New Construction</option>
            </div>
        </div>
    </div>
    
    <div class="filters-bar">
        <div class="filters-content">
            <select><option>Price: Any</option></select>
            <select><option>Beds: Any</option></select>
            <select><option>Baths: Any</option></select>
