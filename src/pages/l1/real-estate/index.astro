            </div>
            
            <div class="property">
                <div class="property-image">
                    <span class="status-badge">For Sale</span>
                    <span class="favorite">♡</span>
                </div>
                <div class="property-details">
                    <div class="property-price">$675,000</div>
                    <div class="property-address">555 Birch Lane, Portland, OR 97201</div>
                    <div class="property-stats">
                        <span>🛏️ 3 bd</span>
