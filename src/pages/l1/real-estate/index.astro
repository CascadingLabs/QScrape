                        <span>📐 1,850 sqft</span>
                    </div>
                    <div class="property-features">
                        <span class="feature">Garage</span>
                        <span class="feature">Pool</span>
                        <span class="feature">Updated Kitchen</span>
                    </div>
                    <div class="property-cta">
                        <button class="primary">View Details</button>
                        <button class="secondary">Contact</button>
                    </div>
                </div>
            </div>
            
            <div class="property">
                <div class="property-image">
                    <span class="status-badge">For Sale</span>
                    <span class="favorite">♡</span>
                </div>
                <div class="property-details">
                    <div class="property-price">$1,250,000</div>
                    <div class="property-address">456 Maple Avenue, Seattle, WA 98101</div>
                    <div class="property-stats">
                        <span>🛏️ 4 bd</span>
                        <span>🚿 3 ba</span>
                        <span>📐 2,400 sqft</span>
                    </div>
                    <div class="property-features">
                        <span class="feature">Water View</span>
                        <span class="feature">Smart Home</span>
                        <span class="feature">Wine Cellar</span>
                    </div>
                    <div class="property-cta">
                        <button class="primary">View Details</button>
                        <button class="secondary">Contact</button>
                    </div>
                </div>
            </div>
            
            <div class="property">
                <div class="property-image">
                    <span class="status-badge">For Sale</span>
                    <span class="favorite">♡</span>
                </div>
                <div class="property-details">
                    <div class="property-price">$525,000</div>
                    <div class="property-address">789 Pine Road, Austin, TX 78701</div>
                    <div class="property-stats">
                        <span>🛏️ 2 bd</span>
