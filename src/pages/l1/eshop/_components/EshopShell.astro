---
interface Props {
  title: string;
  activePage?: 'home' | 'catalog' | 'cart' | 'search' | 'about';
  breadcrumbs?: Array<{ label: string; href?: string }>;
}

const {
  title,
  activePage = 'home',
  breadcrumbs = [],
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} — VaultMart</title>
  <link rel="stylesheet" href="/global.css">
  <slot name="head" />
</head>
<body>
  <div id="container">

    <!-- Header -->
    <div class="headerBar">
      VAULTMART
      <span class="headerMeta">Your Source for Dwarven Goods &amp; Surface Imports</span>
    </div>

    <!-- Nav -->
    <div class="navBar">
      <a href="/l1/eshop/" class={activePage === 'home' ? 'active' : ''}>Home</a>
      <a href="/l1/eshop/catalog" class={activePage === 'catalog' ? 'active' : ''}>Catalog</a>
      <a href="/l1/eshop/cart" class={activePage === 'cart' ? 'active' : ''}>Cart</a>
      <a href="/l1/eshop/search" class={activePage === 'search' ? 'active' : ''}>Search</a>
      <a href="/l1/eshop/about" class={activePage === 'about' ? 'active' : ''}>About</a>
      <span class="navSep">|</span>
      <a href="/l1/news/">Herald</a>
      <a href="/l1/taxes/">ROD Records</a>
      <a href="/l1/scoretap/">ScoreTap</a>
    </div>

    <!-- Breadcrumbs -->
    {breadcrumbs.length > 0 && (
      <div class="breadcrumbs">
        {breadcrumbs.map((bc, i) => (
          <>
            {i > 0 && <span> &gt; </span>}
            {bc.href
              ? <a href={bc.href}>{bc.label}</a>
              : <span id={i === breadcrumbs.length - 1 ? 'crumb-current' : undefined}>{bc.label}</span>
            }
          </>
        ))}
      </div>
    )}

    <!-- Page Content -->
    <slot />

    <!-- Footer -->
    <div class="footerBar">
      &copy; 2026 VaultMart &mdash; A Division of Koganusan Estates LLC &nbsp;|&nbsp;
      VaultMart v2.0.2008 &nbsp;|&nbsp;
      <a href="/l1/eshop/about" style="color:#99bbdd;">About</a> &nbsp;|&nbsp;
      <a href="/l1/eshop/catalog" style="color:#99bbdd;">Catalog</a> &nbsp;|&nbsp;
      <a href="/l1/news/" style="color:#99bbdd;">Mountainhome Herald</a> &nbsp;|&nbsp;
      <a href="/l1/taxes/" style="color:#99bbdd;">ROD Records</a>
    </div>
  </div>

  <!-- Shared product navigation script -->
  <script is:inline>
  function navigateToProduct(sku) {
    var hash = Math.random().toString(36).substring(2, 15);
    var payload = 'VM_v1_Dg4kRp9mXs' +
                  'XXXEEEXXX' +
                  'SKU=' + encodeURIComponent(sku) + '&HASH=' + hash +
                  'XXXEEEXXX' +
                  'bN8wZt3hF6vQ' +
                  'XXXEEEXXX';
    window.location.href = '/l1/eshop/product?item=' + encodeURIComponent(payload);
  }
  </script>
</body>
</html>

<style is:global>
  /* ── Nav active ─────────────────────────────────────────── */
  .navBar a.active { background-color: #003366; color: #ffffff; }
  .navSep { color: #999; margin: 0 2px; font-size: 10px; }
  .headerMeta { float: right; font-size: 10px; font-weight: normal; }

  /* ── Product Grid ───────────────────────────────────────── */
  .product-grid { display: flex; flex-wrap: wrap; align-items: flex-start; padding: 0 15px 10px 15px; }
  .product-card {
    width: 24%;
    margin: 0.5%;
    position: relative;
    border: 1px solid #cccccc;
    background: #ffffff;
    font-size: 11px;
    vertical-align: top;
  }
  .product-card-inner { padding: 0; }
  .product-card-img { width: 100%; height: auto; display: block; border-bottom: 1px solid #cccccc; }
  .product-card-body { padding: 6px; }
  .product-card-name { margin: 4px 0 2px 0; font-weight: bold; font-size: 11px; line-height: 1.3; }
  .product-card-name a { color: #003366; text-decoration: none; cursor: pointer; }
  .product-card-name a:hover { text-decoration: underline; }
  .product-card-excerpt { color: #666; font-size: 10px; margin: 3px 0; line-height: 1.4; }
  .product-card-price { margin-top: 4px; }
  .clearfix::after { content: ""; display: table; clear: both; }

  /* ── Price ──────────────────────────────────────────────── */
  .priceDisplay { color: #cc0000; font-size: 13px; font-weight: bold; }
  .originalPrice { color: #999; text-decoration: line-through; font-size: 10px; }

  /* ── NEW / OOS / SALE Badges ────────────────────────────── */
  .newBadge {
    position: absolute; top: 4px; left: 4px;
    background: #cc0000; color: #fff;
    font-size: 9px; font-weight: bold;
    padding: 2px 5px; z-index: 1;
  }
  .oosBadge {
    position: absolute; top: 4px; right: 4px;
    background: #666; color: #fff;
    font-size: 9px; font-weight: bold;
    padding: 2px 5px; z-index: 1;
  }
  .saleBadge {
    position: absolute; top: 4px; left: 4px;
    background: #cc6600; color: #fff;
    font-size: 9px; font-weight: bold;
    padding: 2px 5px; z-index: 1;
  }
  .statusOos { background: #e0e0e0; color: #666; padding: 2px 8px; font-size: 10px; font-weight: bold; }
  .lowStock { background: #fff3cd; color: #856404; padding: 2px 8px; font-size: 10px; font-weight: bold; }

  /* ── Category Badges ────────────────────────────────────── */
  .categoryBadge { padding: 2px 5px; font-size: 9px; font-weight: bold; white-space: nowrap; display: inline-block; margin-bottom: 3px; }
  .cat-mining    { background: #f7e9c8; color: #5c3d00; }
  .cat-forge     { background: #fdd;    color: #800;    }
  .cat-food      { background: #d4f7d4; color: #1a4d1a; }
  .cat-furniture { background: #d8e8f8; color: #1a3a5c; }
  .cat-surface   { background: #f0e0ff; color: #4d1a6e; }

  /* ── Star Rating ────────────────────────────────────────── */
  .starRating { font-size: 11px; color: #cc7700; display: block; margin: 2px 0; }
  .reviewCount { color: #666; font-size: 10px; margin-left: 3px; }

  /* ── Section Headers ────────────────────────────────────── */
  .sectionHeader {
    background: #003366; color: #fff;
    padding: 4px 15px; margin: 10px 15px 0 15px;
    font-size: 12px; font-weight: bold;
  }
  .sectionSub { padding: 3px 15px; font-size: 10px; color: #666; margin: 0 15px 4px 15px; }

  /* ── Hero Banner ────────────────────────────────────────── */
  .heroBanner {
    background: #003366; color: #fff;
    padding: 14px 15px; margin: 10px 15px;
    border: 2px solid #003366;
  }
  .heroBanner h2 { color: #ffdd44; margin: 0 0 5px 0; font-size: 14px; }
  .heroBanner p  { font-size: 11px; margin: 0; color: #cce; }

  /* ── Category Tiles ─────────────────────────────────────── */
  .categoryTileGrid { overflow: hidden; margin: 6px 15px 10px 15px; }
  .categoryTile {
    float: left; width: 18%; margin: 0.5%;
    border: 1px solid #003366;
    background: #f0f0f0; text-align: center;
    padding: 10px 4px; text-decoration: none;
    color: #003366; font-weight: bold; font-size: 10px;
  }
  .categoryTile:hover { background: #003366; color: #fff; text-decoration: none; }
  .categoryTileIcon { font-size: 18px; display: block; margin-bottom: 4px; }

  /* ── Filter Tabs ────────────────────────────────────────── */
  .filterTabBar {
    background: #f0f0f0; border: 1px solid #999;
    padding: 6px 15px; margin: 8px 15px 0 15px;
    overflow: hidden;
  }
  .filterTab {
    display: inline-block; padding: 3px 10px; margin-right: 3px;
    color: #003366; text-decoration: none;
    border: 1px solid #999; background: #fff;
    cursor: pointer; font-size: 11px;
  }
  .filterTab.active { background: #003366; color: #fff; border-color: #003366; }
  .filterTab:hover  { background: #e0e8f0; text-decoration: none; }
  .filterTab.active:hover { background: #003366; }

  /* ── Page Title ─────────────────────────────────────────── */
  .pageTitle {
    font-size: 16px; font-weight: bold; color: #003366;
    margin: 15px; padding-bottom: 10px;
    border-bottom: 1px solid #cccccc;
  }

  /* ── Sort Bar ───────────────────────────────────────────── */
  .sortBar { padding: 4px 15px; margin: 0 15px; font-size: 11px; color: #666; }
  .sortBar select { width: auto; }
  .sortBar select:disabled { opacity: 0.5; cursor: not-allowed; }
  .l2note { font-size: 9px; color: #999; font-style: italic; margin-left: 6px; }

  /* ── Product Detail ─────────────────────────────────────── */
  .productDetailWrap { overflow: hidden; margin: 8px 15px; }
  .productMainCol { float: left; width: 560px; }
  .productSideCol {
    float: right; width: 200px;
    border: 1px solid #003366; padding: 10px;
    background: #f8f8f8;
  }
  .productTitle { font-size: 16px; font-weight: bold; color: #003366; margin-bottom: 6px; }
  .productImage { border: 1px solid #999; padding: 4px; background: #f0f0f0; margin-bottom: 10px; }
  .productImage img { width: 100%; height: auto; display: block; }
  .productDesc { font-size: 11px; line-height: 1.6; color: #333; margin-bottom: 10px; }
  .productSpecs { width: 100%; border-collapse: collapse; margin-bottom: 10px; font-size: 11px; }
  .productSpecs th { background: #003366; color: #fff; padding: 3px 8px; text-align: left; }
  .productSpecs td { padding: 3px 8px; border-bottom: 1px solid #eee; }
  .productSpecs tr:nth-child(even) td { background: #f9f9f9; }
  .variantRow { margin-bottom: 8px; font-size: 11px; }
  .variantRow label { font-weight: bold; display: block; margin-bottom: 2px; }
  .variantRow select { width: 100%; }
  .variantRow select:disabled { opacity: 0.5; cursor: not-allowed; }
  .variantNote { font-size: 9px; color: #999; font-style: italic; margin-top: 2px; }
  .addToCartBtn { width: 100%; margin-top: 8px; }
  .addToCartBtn:disabled { opacity: 0.5; cursor: not-allowed; }
  .sidePrice { margin-bottom: 8px; }
  .sideSku { font-size: 10px; color: #666; margin-bottom: 6px; }
  .sideStock { margin-bottom: 8px; }

  /* ── Reviews ────────────────────────────────────────────── */
  .reviewItem { border-bottom: 1px solid #eee; padding: 8px 0; font-size: 11px; }
  .reviewItem:last-child { border-bottom: none; }
  .reviewAuthor { font-weight: bold; color: #003366; }
  .reviewDate { color: #999; font-size: 9px; margin-left: 6px; }
  .reviewBody { color: #333; margin-top: 3px; line-height: 1.5; }
  .verifiedBadge {
    background: #c6f6d5; color: #22543d;
    font-size: 8px; font-weight: bold;
    padding: 1px 4px; margin-left: 6px;
  }

  /* ── Search / Mark ──────────────────────────────────────── */
  mark { background: #fffb00; color: #000; font-style: normal; }
  .searchResultItem { border-bottom: 1px solid #ddd; padding: 8px 0; overflow: hidden; }
  .searchResultItem:last-child { border-bottom: none; }
  .searchResultImg { float: left; width: 60px; height: 44px; object-fit: cover; margin-right: 8px; border: 1px solid #ccc; }
  .searchResultName { font-weight: bold; font-size: 12px; color: #003366; }
  .searchResultExcerpt { font-size: 10px; color: #666; margin-top: 2px; }
  .searchResultPrice { font-size: 11px; color: #cc0000; font-weight: bold; margin-top: 2px; }

  /* ── Cart ───────────────────────────────────────────────── */
  .cartTotal { font-size: 13px; font-weight: bold; color: #cc0000; }

  /* ── Promoted / Sponsored ───────────────────────────────── */
  .promoBadge {
    position: absolute; bottom: 4px; right: 4px;
    background: #cc8800; color: #fff;
    font-size: 8px; font-weight: bold;
    padding: 2px 5px; z-index: 1;
  }
  .sponsoredStrip {
    margin: 8px 15px 0 15px;
    border: 1px solid #e6c97a;
    background: #fffbf0;
    padding: 6px 8px 4px 8px;
  }
  .sponsoredLabel {
    font-size: 10px; font-weight: bold; color: #996600;
    text-transform: uppercase; letter-spacing: 0.05em;
    margin-bottom: 4px;
  }
</style>
