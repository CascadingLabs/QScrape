  function stars(rating) {
    var full  = Math.round(rating);
    var empty = 5 - full;
    return '&#9733;'.repeat(full) + '&#9734;'.repeat(empty);
  }

  function catBadgeClass(cat) {
    var map = {
      'Mining & Excavation': 'cat-mining',
      'Forge & Smithing':    'cat-forge',
      'Food & Brewing':      'cat-food',
      'Furniture & Housing': 'cat-furniture',
      'Surface Imports':     'cat-surface'
    };
    return map[cat] || 'cat-mining';
  }

  function decodeItemParam(raw) {
    try {
      var decoded = decodeURIComponent(raw);
      var parts   = decoded.split('XXXEEEXXX');
      for (var i = 0; i < parts.length; i++) {
        if (parts[i].indexOf('SKU=') !== -1) {
          var m = parts[i].match(/SKU=([^&]+)/);
          if (m) return decodeURIComponent(m[1]);
        }
      }
    } catch(e) {}
    return null;
  }

  function buildProductPage(p) {
    // Update page title + breadcrumb
    document.title = p.name + ' — VaultMart';
    var crumb = document.getElementById('crumb-current');
    if (crumb) crumb.textContent = p.name;

    // Specs rows
    var specRows = Object.keys(p.specs).map(function(k) {
      return '<tr><td style="font-weight:bold;width:35%;">' + k + '</td><td>' + p.specs[k] + '</td></tr>';
    }).join('');

    // Variant selects (disabled — L1; full interaction in L2)
    var variantHtml = p.variants.map(function(v, vi) {
      var opts = v.options.map(function(o) {
        var label = o.value;
        if (o.priceModifier > 0)  label += ' (+' + o.priceModifier.toFixed(2) + ' GS)';
        if (o.priceModifier < 0)  label += ' (' + o.priceModifier.toFixed(2) + ' GS)';
        if (!o.inStock) label += ' [Out of Stock]';
        return '<option value="' + o.value + '"' +
               ' data-price-mod="' + o.priceModifier + '"' +
               ' data-in-stock="' + o.inStock + '">' + label + '</option>';
      }).join('');
      return '<div class="variantRow">' +
        '<label for="variant-' + vi + '">' + v.label + '</label>' +
        '<select id="variant-' + vi + '" disabled style="opacity:0.5;">' + opts + '</select>' +
        '</div>';
    }).join('');

    // Reviews
    var reviewHtml = p.reviews.map(function(r) {
      return '<div class="reviewItem">' +
        '<div><span class="reviewAuthor">' + r.author + '</span>' +
        '<span class="reviewDate">' + r.date + '</span>' +
        (r.verified ? '<span class="verifiedBadge">VERIFIED</span>' : '') +
        '&nbsp;<span style="color:#cc7700;">' + '&#9733;'.repeat(Math.round(r.rating)) + '&#9734;'.repeat(5 - Math.round(r.rating)) + '</span>' +
        '</div>' +
        '<div class="reviewBody">' + r.body + '</div>' +
        '</div>';
    }).join('');

    // Related products
    var relatedHtml = p.relatedSkus.map(function(sku) {
      var rel = productData[sku];
      if (!rel) return '';
      return '<div style="margin-bottom:4px;">' +
        '<a href="javascript:void(0)" onclick="navigateToProduct(\'' + sku + '\');return false;">' + rel.name + '</a>' +
        '<span style="color:#cc0000;font-size:10px;"> &mdash; ' + rel.basePrice.toFixed(2) + ' GS</span>' +
        '</div>';
    }).join('');

    var stockBadge;
    if (!p.inStock) {
      stockBadge = '<span class="statusOos">Out of Stock</span>';
    } else if (p.stock !== undefined && p.stock <= 5) {
      stockBadge = '<span class="lowStock" data-stock="' + p.stock + '">Only ' + p.stock + ' left!</span>';
    } else if (p.stock !== undefined) {
      stockBadge = '<span class="statusApproved" data-stock="' + p.stock + '">In Stock</span>';
    } else {
      stockBadge = '<span class="statusApproved">In Stock</span>';
    }

    var priceHtml = p.salePrice
      ? '<span style="color:#999;text-decoration:line-through;font-size:10px;">' + p.basePrice.toFixed(2) + ' GS</span> ' +
        '<span id="product-price" class="priceDisplay">' + p.salePrice.toFixed(2) + ' Gold Sovereigns</span>'
      : '<span id="product-price" class="priceDisplay">' + p.basePrice.toFixed(2) + ' Gold Sovereigns</span>';

    var html =
      '<div class="productDetailWrap clearfix">' +
        '<div class="productMainCol">' +
          '<div class="productTitle">' + p.name + '</div>' +
          '<div class="productImage"><img src="' + p.image + '" alt="' + p.name + '"></div>' +
          '<p class="productDesc">' + p.description + '</p>' +
          '<table class="productSpecs">' +
            '<thead><tr><th colspan="2">Specifications</th></tr></thead>' +
            '<tbody>' + specRows + '</tbody>' +
          '</table>' +
          '<div class="sectionHeader" style="margin:8px 0 0 0;">Customer Reviews</div>' +
          '<div style="padding:0 0 8px 0;">' + reviewHtml + '</div>' +
        '</div>' +
        '<div class="productSideCol">' +
          '<div class="sideSku">SKU: ' + p.sku + '</div>' +
          '<div class="sideStock">' + stockBadge + '</div>' +
          '<div class="sidePrice">' + priceHtml + '</div>' +
          variantHtml +
          '<div class="variantNote">Variant selection available in the full store.</div>' +
          '<input type="button" value="Add to Cart" class="aspNetButton addToCartBtn" disabled>' +
          '<div class="variantNote" style="margin-top:4px;">Online ordering available in the full store.</div>' +
          '<hr>' +
          '<div style="font-size:10px;font-weight:bold;margin-bottom:4px;color:#003366;">Related Products</div>' +
          relatedHtml +
          '<hr>' +
          '<div style="font-size:10px;"><a href="/l1/eshop/catalog">&#171; Back to Catalog</a></div>' +
        '</div>' +
      '</div>';

    document.getElementById('product-content').innerHTML = html;
  }

  var params    = new URLSearchParams(window.location.search);
  var itemParam = params.get('item');
  var sku       = itemParam ? decodeItemParam(itemParam) : null;
  var product   = sku ? productData[sku] : null;

  if (product) {
    buildProductPage(product);
  } else {
    document.getElementById('product-not-found').style.display = 'block';
  }
  </script>

