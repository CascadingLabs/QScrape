---
import SiteShell from './_components/SiteShell.astro';
---
<SiteShell title="Player — ScoreTap" activePage="teams">

  <style>
    .player-detail-container { max-width: 1100px; margin: 14px auto; padding: 0 12px; display: flex; flex-direction: column; gap: 10px; }
    .player-header-card { background: linear-gradient(180deg, #181828 0%, var(--bg-panel) 100%); border: 1px solid var(--border); border-top: 3px solid var(--accent); padding: 20px; }
    .player-name-display { font-size: 1.6rem; font-weight: 900; color: var(--text-bright); text-transform: uppercase; letter-spacing: 1px; line-height: 1.2; margin-bottom: 4px; }
    .player-real-name { font-size: 12px; color: var(--text-dim); margin-bottom: 10px; font-style: italic; }
    .player-meta-row { display: flex; gap: 14px; align-items: center; flex-wrap: wrap; font-size: 11px; color: var(--text-dim); }
    .player-meta-row .team-link { color: var(--accent); font-weight: 700; }
    .player-meta-row .team-link:hover { text-decoration: underline; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid var(--border); }
    .stat-box { padding: 12px; text-align: center; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); background: var(--bg-panel); }
    .stat-box:last-child { border-right: none; }
    .stat-box .stat-value { font-size: 1.3rem; font-weight: 900; color: var(--accent); font-family: 'Courier New', monospace; }
    .stat-box .stat-label { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
    #player-not-found { text-align: center; padding: 40px; color: var(--text-dim); font-size: 1rem; border: 1px solid var(--border); background: var(--bg-panel); }
  </style>

  <div class="player-detail-container">
    <div class="breadcrumb">
      <a href="/l1/scoretap/">Home</a> &rsaquo;
      <a href="/l1/scoretap/teams">Teams</a> &rsaquo;
      <span id="breadcrumb-team">Team</span> &rsaquo;
      <span id="breadcrumb-player">Player Detail</span>
    </div>

    <div id="player-content">
      <!-- Populated by JS -->
    </div>

    <div id="player-not-found" style="display:none;">
      Player not found. <a href="/l1/scoretap/teams" style="color:var(--accent);">Return to teams</a>
    </div>
  </div>

