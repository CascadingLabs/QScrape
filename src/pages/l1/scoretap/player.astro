          { headline: 'RLCS 2026 Spring Split Prize Pool Revealed at $2.5 Million', time: '12h ago', href: '/l1/scoretap/article?id=rlcs-prize-pool' },
          { headline: 'Team BDS Secure RLCS Spring Regional After 3-1 Win Over Karmine Corp', time: '22h ago', href: '/l1/scoretap/article?id=bds-karmine-win' }
        ]
      },
      'rizzo': {
        id: 'rizzo', name: 'Rizzo', realName: 'Dillon Rizzo',
        team: 'Cloud9', teamId: 'cloud9', game: 'rl', gameLabel: 'Rocket League',
        role: 'Player', nationality: 'USA', age: 26,
        stats: { rating: '0.96', kd: '\u2014', hsPercent: '\u2014', mapsPlayed: 280 },
        career: [
          { year: '2023\u2013present', team: 'Cloud9', role: 'Player' },
          { year: '2017\u20132023', team: 'G2 Esports', role: 'Player' }
        ],
        achievements: [
          { event: 'RLCS Spring 2026', placement: 'Regional Major (ongoing)', eventId: 'rlcs-spring-2026' }
        ],
        news: [
          { headline: 'RLCS 2026 Spring Split Prize Pool Revealed at $2.5 Million', time: '12h ago', href: '/l1/scoretap/article?id=rlcs-prize-pool' },
