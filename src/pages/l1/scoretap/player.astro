        ]
      }
    };

    function buildPlayerPage(p) {
      document.title = p.name + ' \u2014 ScoreTap';
      var breadTeam = document.getElementById('breadcrumb-team');
      breadTeam.innerHTML = '<a href="/l1/scoretap/team?id=' + p.teamId + '">' + p.team + '</a>';
      document.getElementById('breadcrumb-player').textContent = p.name;

      // Career rows
      var careerRows = p.career.map(function(c) {
        return '<tr>' +
          '<td style="color:var(--text-dim);">' + c.year + '</td>' +
          '<td style="font-weight:700;color:var(--text-bright);">' + c.team + '</td>' +
          '<td>' + c.role + '</td>' +
        '</tr>';
      }).join('');

      // Achievement rows
      var achieveRows = p.achievements.map(function(a) {
        var eventCell = a.eventId
          ? '<a class="event-link" href="/l1/scoretap/event?id=' + a.eventId + '" style="color:var(--text);"><span style="color:var(--text);">' + a.event + '</span></a>'
          : a.event;
        var placementClass = (a.placement.indexOf('Champion') !== -1 || a.placement.indexOf('1st') !== -1) ? ' style="color:var(--accent);font-weight:700;"' : '';
        return '<tr>' +
          '<td>' + eventCell + '</td>' +
          '<td' + placementClass + '>' + a.placement + '</td>' +
        '</tr>';
      }).join('');

      // News items
      var newsItems = p.news.map(function(n) {
        return '<li><a href="' + (n.href || '#') + '">' + n.headline + '</a><div class="news-meta-small">' + n.time + '</div></li>';
      }).join('');

      var html =
        // Player Header Card
        '<div class="player-header-card">' +
          '<div class="player-name-display">' + p.name + '</div>' +
          '<div class="player-real-name">' + p.realName + '</div>' +
          '<div class="player-meta-row">' +
            '<span class="game-tag ' + p.game + '">' + p.gameLabel + '</span>' +
            '<a class="team-link" href="/l1/scoretap/team?id=' + p.teamId + '">' + p.team + '</a>' +
            '<span>' + p.role + '</span>' +
            '<span>' + p.nationality + '</span>' +
            '<span>Age: ' + p.age + '</span>' +
          '</div>' +
        '</div>' +

        // Statistics Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Statistics</span></div>' +
          '<div class="stat-grid">' +
            '<div class="stat-box"><div class="stat-value">' + p.stats.rating + '</div><div class="stat-label">Rating</div></div>' +
            '<div class="stat-box"><div class="stat-value">' + p.stats.kd + '</div><div class="stat-label">K/D Ratio</div></div>' +
            '<div class="stat-box"><div class="stat-value">' + p.stats.hsPercent + '</div><div class="stat-label">HS%</div></div>' +
            '<div class="stat-box"><div class="stat-value">' + p.stats.mapsPlayed + '</div><div class="stat-label">Maps Played</div></div>' +
          '</div>' +
        '</div>' +

        // Career History Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Career History</span></div>' +
          '<table>' +
            '<thead><tr><th>Year</th><th>Team</th><th>Role</th></tr></thead>' +
            '<tbody>' + careerRows + '</tbody>' +
          '</table>' +
        '</div>' +

        // Achievements Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Achievements</span></div>' +
          '<table>' +
            '<thead><tr><th>Event</th><th>Placement</th></tr></thead>' +
            '<tbody>' + achieveRows + '</tbody>' +
          '</table>' +
        '</div>' +

        // Related News Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Related News</span><a class="widget-link" href="/l1/scoretap/news">All News</a></div>' +
          '<ul class="news-list">' + newsItems + '</ul>' +
        '</div>';

      document.getElementById('player-content').innerHTML = html;
    }

    var params = new URLSearchParams(window.location.search);
    var playerId = params.get('id');
    var player = playerId ? PLAYERS[playerId] : null;

    if (player) {
      buildPlayerPage(player);
    } else {
      document.getElementById('player-not-found').style.display = 'block';
    }
  </script>

</SiteShell>
