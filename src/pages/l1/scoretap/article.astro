  // ── RENDERING ──────────────────────────────────────────────────────────────

  var GAME_LABELS = { cs2: 'CS2', valorant: 'Valorant', lol: 'LoL', dota2: 'Dota 2', rl: 'Rocket League' };

  function getParam(key) {
    return new URLSearchParams(window.location.search).get(key);
  }

  function gameTagHTML(game) {
    return '<span class="game-tag ' + game + '">' + (GAME_LABELS[game] || game.toUpperCase()) + '</span>';
  }

  function renderRelated(ids) {
    if (!ids || !ids.length) return '';
    var cards = ids.slice(0, 3).map(function(id) {
      var a = ARTICLES[id];
      if (!a) return '';
      return '<div class="related-card"><a class="related-headline" href="/l1/scoretap/article?id=' + a.id + '">' + a.title + '</a><div class="related-meta">' + gameTagHTML(a.game) + '<span>' + a.date.split('\u00b7')[1].trim() + '</span></div></div>';
    }).join('');
    return '<div class="widget" style="margin-bottom:10px;"><div class="widget-header"><span class="widget-title">Related Articles</span><a class="widget-link" href="/l1/scoretap/news">All News</a></div><div class="related-grid">' + cards + '</div></div>';
  }

  function renderArticle(article) {
    var bodyHTML = article.body.join('');

    var headings = [];
    var idx = 0;
    bodyHTML = bodyHTML.replace(/<h2>(.*?)<\/h2>/g, function(match, text) {
      idx++;
      var anchorId = 'section-' + idx;
      headings.push({ id: anchorId, text: text });
      return '<h2 id="' + anchorId + '">' + text + '</h2>';
    });

    var tocHTML = '';
    if (headings.length >= 2) {
      var tocItems = headings.map(function(h) {
        return '<li><a href="#' + h.id + '">' + h.text + '</a></li>';
      }).join('');
      tocHTML = '<div class="article-toc"><div class="article-toc-title" onclick="var list=this.nextElementSibling;if(list.style.display===\'none\'){list.style.display=\'\';this.classList.remove(\'collapsed\');}else{list.style.display=\'none\';this.classList.add(\'collapsed\');}">Contents</div><ol class="article-toc-list">' + tocItems + '</ol></div>';
    }

    return [
      '<div class="article-card">',
        '<div class="article-header">',
          '<div class="article-meta-top">',
            gameTagHTML(article.game),
            '<span class="event-badge live" style="font-size:9px;">' + article.event + '</span>',
          '</div>',
          '<div class="article-title">' + article.title + '</div>',
          '<div class="article-byline">',
            '<span>By <span class="author">' + article.author + '</span></span>',
            '<span>' + article.date + '</span>',
          '</div>',
        '</div>',
        '<div class="article-body">' + tocHTML + bodyHTML + '</div>',
      '</div>',
      renderRelated(article.related),
    ].join('');
  }

  function buildSidebarNews(currentId) {
    return Object.values(ARTICLES)
      .filter(function(a) { return a.id !== currentId; })
      .slice(0, 10)
      .map(function(a) {
        return '<li><a href="/l1/scoretap/article?id=' + a.id + '">' + a.title + '</a><div class="sidebar-news-meta">' + gameTagHTML(a.game) + ' &nbsp;' + a.date.split('\u00b7')[1].trim() + '</div></li>';
      }).join('');
  }

  var id = getParam('id');
  var article = id ? ARTICLES[id] : null;

  if (article) {
    document.getElementById('breadcrumb-title').textContent = article.title;
    document.getElementById('article-content').innerHTML = renderArticle(article);
    document.getElementById('sidebar-news-list').innerHTML = buildSidebarNews(id);
    document.title = article.title + ' \u2014 ScoreTap';
  } else {
    document.getElementById('article-not-found').style.display = '';
    document.getElementById('article-breadcrumb').style.display = 'none';
    document.getElementById('sidebar-news-list').innerHTML = buildSidebarNews(null);
  }
  </script>

