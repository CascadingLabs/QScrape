  <script is:inline>
    // Game filter
    var tabs = document.querySelectorAll('.game-tab');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        var filter = tab.getAttribute('data-filter');
        var cards = document.querySelectorAll('.event-card[data-game]');
        cards.forEach(function(card) {
          if (filter === 'all' || card.getAttribute('data-game') === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
        // update section counts
        ['live-events', 'upcoming-events', 'done-events'].forEach(function(sectionId) {
          var section = document.getElementById(sectionId);
          if (!section) return;
          var visible = section.querySelectorAll('.event-card:not([style*="display: none"]):not([style*="display:none"])').length;
          var label = document.getElementById(sectionId.replace('-events', '-count-label'));
          if (label) label.textContent = visible + (visible === 1 ? ' event' : ' events');
        });
      });
    });
  </script>

</SiteShell>
