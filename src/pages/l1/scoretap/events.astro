---
import SiteShell from './_components/SiteShell.astro';
---
<SiteShell title="Events — ScoreTap" activePage="events">

  <style>
    .events-container {
      max-width: 1280px;
      margin: 10px auto;
      padding: 0 10px;
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 10px;
    }
    .events-main { min-width: 0; }
    .events-sidebar { min-width: 0; }

    /* section headers */
    .section-header {
      background: var(--bg-header);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      padding: 6px 12px;
      margin-bottom: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .section-title {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--accent);
    }
    .section-count {
      font-size: 10px;
      color: var(--text-dim);
    }

    /* event card grid */
    .event-cards {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border: 1px solid var(--border);
      border-top: none;
      margin-bottom: 10px;
    }
    .event-card {
      background: var(--bg-panel);
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 12px 14px;
      cursor: pointer;
      transition: background 0.1s;
    }
    .event-card:nth-child(even) { border-right: none; }
    .event-card:hover { background: #131320; }
    .event-card[data-game] { display: block; }

    .event-card-top {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 7px;
    }
    .event-card-name {
      font-size: 11px;
      font-weight: 700;
      color: var(--text-bright);
      text-transform: uppercase;
      letter-spacing: 0.4px;
      line-height: 1.3;
      margin-bottom: 4px;
    }
    .event-card-meta {
      font-size: 10px;
      color: var(--text-dim);
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .event-card-meta span { display: flex; align-items: center; gap: 3px; }

    .event-prize {
      font-size: 11px;
      font-weight: 700;
      color: var(--green);
      font-family: 'Courier New', monospace;
    }

    .event-progress {
      height: 3px;
      background: #1c1c2c;
      margin-top: 8px;
      position: relative;
      overflow: hidden;
    }
    .event-progress-fill {
      height: 100%;
      background: var(--accent);
      transition: width 0.3s;
    }
    .event-progress-fill.upcoming { background: #404058; }
    .event-progress-fill.done { background: #303044; }

    .event-teams-row {
      display: flex;
      gap: 4px;
      flex-wrap: wrap;
      margin-top: 7px;
    }
    .event-team-chip {
      font-size: 9px;
      font-weight: 700;
      color: var(--text-dim);
      background: #12121e;
      border: 1px solid #252535;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .event-team-chip.highlight { color: var(--accent); border-color: #ff6b0030; }

    /* sidebar */
    .sidebar-section { margin-bottom: 10px; }
    .sidebar-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 6px 10px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
    }
    .sidebar-row:last-child { border-bottom: none; }
    .sidebar-row:nth-child(odd)  { background: var(--bg-panel); }
    .sidebar-row:nth-child(even) { background: var(--bg-row-alt); }
    .sidebar-row:hover { background: #131320; cursor: pointer; }
    .sidebar-event-name { color: var(--text); font-weight: 600; flex: 1; line-height: 1.3; }
    .sidebar-event-date { font-size: 10px; color: var(--text-dim); text-align: right; white-space: nowrap; margin-left: 8px; }
  </style>

  <!-- Game filter -->
  <div id="game-filter">
    <button class="game-tab active" data-filter="all">All Games</button>
    <button class="game-tab" data-filter="cs2">CS2</button>
    <button class="game-tab" data-filter="valorant">Valorant</button>
    <button class="game-tab" data-filter="lol">LoL</button>
    <button class="game-tab" data-filter="dota2">Dota 2</button>
    <button class="game-tab" data-filter="rl">Rocket League</button>
