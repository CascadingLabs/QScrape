---
import SiteShell from './_components/SiteShell.astro';
---
<SiteShell title="Team — ScoreTap" activePage="teams">

  <style>
    .team-detail-container {
      max-width: 1100px;
      margin: 14px auto;
      padding: 0 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .team-header-card {
      background: linear-gradient(180deg, #181828 0%, var(--bg-panel) 100%);
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      padding: 20px;
      display: flex;
      align-items: center;
      gap: 20px;
    }
    .team-header-logo {
      width: 80px;
      height: 80px;
      background: #10101c;
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--accent);
      flex-shrink: 0;
    }
    .team-header-info {
      flex: 1;
    }
    .team-header-name {
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--text-bright);
      text-transform: uppercase;
      letter-spacing: 1px;
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .team-header-meta {
      display: flex;
      gap: 12px;
      align-items: center;
      flex-wrap: wrap;
      font-size: 11px;
      color: var(--text-dim);
      margin-bottom: 8px;
    }
    .team-record-bar {
      display: flex;
      gap: 10px;
      align-items: center;
      font-size: 12px;
    }
    .team-record-bar .wins { color: var(--green); font-weight: 700; }
    .team-record-bar .losses { color: var(--red); font-weight: 700; }
    .team-record-bar .pct { color: var(--text-bright); font-weight: 700; font-family: 'Courier New', monospace; }
    .team-stat-row {
      display: flex;
      gap: 20px;
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 6px;
    }
    .team-stat-row .label { color: var(--text-dim); }
    .team-stat-row .value { color: var(--text-bright); font-weight: 700; }
    .prize-total {
      font-size: 1.3rem;
      font-weight: 900;
      color: var(--green);
      font-family: 'Courier New', monospace;
      padding: 14px;
      text-align: center;
      background: var(--bg-panel);
      border: 1px solid var(--border);
      border-top: none;
    }
    .roster-role { color: var(--accent); font-weight: 600; }
    .placement-1st { color: var(--accent); font-weight: 700; }
    .event-link { color: var(--text); }
    .event-link:hover { color: var(--accent); text-decoration: underline; }
    #team-not-found {
      text-align: center;
      padding: 40px;
      color: var(--text-dim);
      font-size: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-panel);
    }
  </style>

  <div class="team-detail-container">
    <div class="breadcrumb">
      <a href="/l1/scoretap/">Home</a> &rsaquo;
      <a href="/l1/scoretap/teams">Teams</a> &rsaquo;
      <span id="breadcrumb-team">Team Detail</span>
    </div>

    <div id="team-content">
      <!-- Populated by JS -->
    </div>

    <div id="team-not-found" style="display:none;">
      Team not found. <a href="/l1/scoretap/teams" style="color:var(--accent);">Return to teams</a>
    </div>
  </div>

