    function buildTeamPage(t) {
      document.title = t.name + ' \u2014 ScoreTap';
      document.getElementById('breadcrumb-team').textContent = t.name;

      var w = t.record.wins;
      var l = t.record.losses;
      var pct = Math.round((w / (w + l)) * 100) + '%';

      var rankInfo = t.rank;
      if (t.rankPoints) rankInfo += ' \u00b7 ' + t.rankPoints;

      // Roster rows
      var rosterRows = t.roster.map(function(p) {
        return '<tr>' +
          '<td style="font-weight:700;color:var(--text-bright);">' + p.name + '</td>' +
          '<td class="roster-role">' + p.role + '</td>' +
          '<td style="color:var(--text-dim);">' + p.nationality + '</td>' +
        '</tr>';
      }).join('');

      // Recent results rows
      var resultRows = t.recentResults.map(function(r) {
        var eventCell = r.eventId
          ? '<a class="event-link" href="/l1/scoretap/event?id=' + r.eventId + '">' + r.event + '</a>'
          : r.event;
        var placementClass = (r.placement.indexOf('Champion') !== -1 || r.placement.indexOf('1st') !== -1) ? ' class="placement-1st"' : '';
        return '<tr>' +
          '<td>' + eventCell + '</td>' +
          '<td' + placementClass + '>' + r.placement + '</td>' +
          '<td style="color:var(--text-dim);">' + r.prize + '</td>' +
        '</tr>';
      }).join('');

      // News items
      var newsItems = t.news.map(function(n) {
        return '<li><a href="' + (n.href || '#') + '">' + n.headline + '</a><div class="news-meta-small">' + n.time + '</div></li>';
      }).join('');

      var html =
        // Team Header Card
        '<div class="team-header-card">' +
          '<div class="team-header-logo">' + t.abbr + '</div>' +
          '<div class="team-header-info">' +
            '<div class="team-header-name">' + t.name + '</div>' +
            '<div class="team-header-meta">' +
              '<span class="game-tag ' + t.game + '">' + t.gameLabel + '</span>' +
              '<span>' + t.regionShort + '</span>' +
              '<span>' + rankInfo + '</span>' +
            '</div>' +
            '<div class="team-record-bar">' +
              '<span class="wins">W ' + w + '</span>' +
              '<span class="losses">L ' + l + '</span>' +
              '<span class="pct">' + pct + '</span>' +
            '</div>' +
            '<div class="team-stat-row">' +
              '<span><span class="label">Founded:</span> <span class="value">' + t.founded + '</span></span>' +
              '<span><span class="label">Coach:</span> <span class="value">' + t.coach + '</span></span>' +
            '</div>' +
          '</div>' +
        '</div>' +

        // Roster Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Roster</span></div>' +
          '<table>' +
            '<thead><tr><th>Player</th><th>Role</th><th>Nationality</th></tr></thead>' +
            '<tbody>' + rosterRows + '</tbody>' +
          '</table>' +
        '</div>' +

        // Recent Results Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Recent Results</span></div>' +
          '<table>' +
            '<thead><tr><th>Event</th><th>Placement</th><th>Prize</th></tr></thead>' +
            '<tbody>' + resultRows + '</tbody>' +
          '</table>' +
        '</div>' +

        // Prize Winnings Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Prize Winnings (2025\u20132026)</span></div>' +
          '<div class="prize-total">' + t.prizeWinnings + '</div>' +
        '</div>' +

        // Related News Widget
        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Related News</span><a class="widget-link" href="/l1/scoretap/news">All News</a></div>' +
          '<ul class="news-list">' + newsItems + '</ul>' +
        '</div>';

      document.getElementById('team-content').innerHTML = html;
    }

    var params = new URLSearchParams(window.location.search);
    var teamId = params.get('id');
    var team = teamId ? TEAMS[teamId] : null;

    if (team) {
      buildTeamPage(team);
    } else {
      document.getElementById('team-not-found').style.display = 'block';
    }
  </script>

</SiteShell>
