        team2: { name: 'Cloud9',      full: 'Cloud9',      abbr: 'C9', region: 'North America', teamId: 'cloud9' },
        score1: 2,
        score2: 1,
        status: 'LIVE',
        statusNote: 'Game 4 · Overtime',
        event: 'RLCS 2026 — Spring Split',
        eventStage: 'Main Event — Lower Bracket R2',
        date: 'March 11, 2026',
        game: 'rl',
        gameTag: '<span class="game-tag rl">Rocket League</span>',
        maps: [
          { map: 'Game 1', score1: 3, score2: 1, winner: 1,    status: 'Finished' },
