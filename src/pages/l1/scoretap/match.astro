          { name: 'b1t',        team: 'NAVI', kills: 26, deaths: 27, assists: 11, rating: '0.98', hs: '38%' },
          { name: 'NiKo',       team: 'G2',   kills: 33, deaths: 25, assists: 7,  rating: '1.22', hs: '58%' },
          { name: 'HooXi',      team: 'G2',   kills: 18, deaths: 28, assists: 14, rating: '0.81', hs: '31%' },
          { name: 'huNter-',    team: 'G2',   kills: 27, deaths: 26, assists: 9,  rating: '1.05', hs: '47%' }
        ],
        news: [
          { headline: 'G2 NiKo: "We Came to Katowice to Win Everything, Not Just Qualify"', time: '16h ago', href: '/l1/scoretap/article?id=g2-niko-interview' },
          { headline: 'NAVI Confirm Signing of Rifler blameF Ahead of Major Qualifier', time: '4h ago', href: '/l1/scoretap/article?id=navi-blamef-signing' },
          { headline: 'ZywOo Sets New Career-High Rating Record at IEM Katowice 2026', time: '2h ago', href: '/l1/scoretap/article?id=zywoo-katowice-record' }
        ]
      },
      'match-002': {
        id: 'match-002',
        team1: { name: 'Sentinels', full: 'Sentinels', abbr: 'SEN',  region: 'North America', teamId: 'sentinels' },
        team2: { name: 'LOUD',      full: 'LOUD',      abbr: 'LOUD', region: 'Brazil' },
        score1: 9,
        score2: 7,
        status: 'LIVE',
        statusNote: 'Map 1 · Attack Side',
        event: 'VCT Americas 2026',
        eventStage: 'Group Stage — Week 4',
        date: 'March 11, 2026',
        game: 'valorant',
        gameTag: '<span class="game-tag valorant">Valorant</span>',
        maps: [
          { map: 'Ascent', score1: 9,   score2: 7,   winner: null, status: 'Live · Attack' },
          { map: 'Sunset', score1: '—', score2: '—', winner: null, status: 'Not played' },
          { map: 'Haven',  score1: '—', score2: '—', winner: null, status: 'Not played' }
        ],
