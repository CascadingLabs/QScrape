        ],
        players: [
          { name: 'Fairy Peak', team: 'TL', kills: 24, deaths: 18, assists: 15, rating: '1.31', hs: '—' },
          { name: 'jstn',       team: 'TL', kills: 19, deaths: 20, assists: 22, rating: '1.08', hs: '—' },
          { name: 'Squishy',    team: 'TL', kills: 21, deaths: 19, assists: 18, rating: '1.14', hs: '—' },
          { name: 'Torment',    team: 'C9', kills: 22, deaths: 22, assists: 17, rating: '1.02', hs: '—' },
          { name: 'Gimmick',    team: 'C9', kills: 18, deaths: 21, assists: 20, rating: '0.96', hs: '—' },
          { name: 'Rizzo',      team: 'C9', kills: 15, deaths: 21, assists: 24, rating: '0.91', hs: '—' }
        ],
        news: [
          { headline: 'Team Liquid Unveil Revamped RLCS Roster Ahead of Spring Split', time: '4d ago', href: '/l1/scoretap/article?id=liquid-rl-roster' },
          { headline: 'RLCS 2026 Spring Split Prize Pool Revealed at $2.5 Million', time: '12h ago', href: '/l1/scoretap/article?id=rlcs-prize-pool' },
          { headline: 'Team BDS Secure RLCS Spring Regional After 3-1 Win Over Karmine Corp', time: '22h ago', href: '/l1/scoretap/article?id=bds-karmine-win' }
        ]
      }
    };

    function getRatingClass(r) {
      var n = parseFloat(r);
      if (isNaN(n)) return '';
      if (n >= 1.2)  return 'rating-high';
      if (n >= 0.95) return 'rating-mid';
      return 'rating-low';
    }

    function buildMatchPage(m) {
      document.title = m.team1.name + ' vs ' + m.team2.name + ' — ScoreTap';
      document.getElementById('breadcrumb-match').textContent = m.team1.name + ' vs ' + m.team2.name;

      var statusHtml = m.status === 'LIVE'
        ? '<span class="live-pill">LIVE</span> ' + m.statusNote
        : m.status;

      // Map rows
      var mapRows = m.maps.map(function(mp) {
        var w1 = mp.winner === 1 ? 'td-win' : (mp.winner === 2 ? 'td-loss' : '');
        var w2 = mp.winner === 2 ? 'td-win' : (mp.winner === 1 ? 'td-loss' : '');
        return '<tr>' +
          '<td class="td-map">' + mp.map + '</td>' +
          '<td class="' + w1 + '">' + mp.score1 + '</td>' +
          '<td class="' + w2 + '">' + mp.score2 + '</td>' +
          '<td style="color:var(--text-dim);font-size:10px;">' + mp.status + '</td>' +
        '</tr>';
      }).join('');

      // Player rows
      var playerRows = m.players.map(function(p) {
        return '<tr>' +
          '<td style="font-weight:700;color:var(--text-bright);">' + p.name + '</td>' +
          '<td style="color:var(--text-dim);">' + p.team + '</td>' +
          '<td class="stat-highlight">' + p.kills + '</td>' +
          '<td>' + p.deaths + '</td>' +
          '<td>' + p.assists + '</td>' +
          '<td>' + p.hs + '</td>' +
          '<td class="' + getRatingClass(p.rating) + '">' + p.rating + '</td>' +
        '</tr>';
      }).join('');

      // News items
      var newsItems = m.news.map(function(n) {
        return '<li><a href="' + (n.href || '#') + '">' + n.headline + '</a><div class="news-meta-small">' + n.time + '</div></li>';
      }).join('');

      var team1Href = m.team1.teamId ? '/l1/scoretap/team?id=' + m.team1.teamId : '/l1/scoretap/teams';
      var team2Href = m.team2.teamId ? '/l1/scoretap/team?id=' + m.team2.teamId : '/l1/scoretap/teams';

      var html =
        '<div class="match-header-card">' +
          '<div class="match-event-info">' +
            m.gameTag + ' &nbsp; <span>' + m.event + '</span> &nbsp;&middot;&nbsp; ' + m.eventStage + ' &nbsp;&middot;&nbsp; ' + m.date +
          '</div>' +
          '<div class="teams-row">' +
            '<div class="team-block">' +
              '<a href="' + team1Href + '" style="text-decoration:none;"><div class="team-logo-placeholder">' + m.team1.abbr + '</div></a>' +
              '<div class="team-full-name"><a href="' + team1Href + '" style="color:inherit;">' + m.team1.full + '</a></div>' +
              '<div class="team-region">' + m.team1.region + '</div>' +
            '</div>' +
            '<div class="score-center">' +
              '<div class="main-score" id="detail-score">' + m.score1 + ' : ' + m.score2 + '</div>' +
              '<div class="score-status">' + statusHtml + '</div>' +
            '</div>' +
            '<div class="team-block">' +
              '<a href="' + team2Href + '" style="text-decoration:none;"><div class="team-logo-placeholder">' + m.team2.abbr + '</div></a>' +
              '<div class="team-full-name"><a href="' + team2Href + '" style="color:inherit;">' + m.team2.full + '</a></div>' +
              '<div class="team-region">' + m.team2.region + '</div>' +
            '</div>' +
          '</div>' +
        '</div>' +

        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Map Breakdown</span></div>' +
          '<table>' +
            '<thead><tr>' +
              '<th>Map</th>' +
              '<th>' + m.team1.name + '</th>' +
              '<th>' + m.team2.name + '</th>' +
              '<th>Status</th>' +
            '</tr></thead>' +
            '<tbody>' + mapRows + '</tbody>' +
          '</table>' +
        '</div>' +

        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Player Statistics</span></div>' +
          '<table>' +
            '<thead><tr>' +
              '<th>Player</th><th>Team</th><th>K</th><th>D</th><th>A</th><th>HS%</th><th>Rating</th>' +
            '</tr></thead>' +
            '<tbody>' + playerRows + '</tbody>' +
          '</table>' +
        '</div>' +

        '<div class="widget">' +
          '<div class="widget-header"><span class="widget-title">&#9632; Related News</span><a class="widget-link" href="/l1/scoretap/news">All News</a></div>' +
          '<ul class="news-list">' + newsItems + '</ul>' +
        '</div>';

      document.getElementById('match-content').innerHTML = html;
    }

    var params  = new URLSearchParams(window.location.search);
    var matchId = params.get('id');
    var match   = matchId ? matchData[matchId] : null;

    if (match) {
      buildMatchPage(match);
    } else {
      document.getElementById('match-not-found').style.display = 'block';
    }
  </script>

</SiteShell>
