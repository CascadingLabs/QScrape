---
import SiteShell from './_components/SiteShell.astro';
---
<SiteShell title="Match Details — ScoreTap">

  <div class="match-detail-container">
    <div class="breadcrumb">
      <a href="/l1/scoretap/">Home</a> &rsaquo;
      <a href="/l1/scoretap/">Scores</a> &rsaquo;
      <span id="breadcrumb-match">Match Detail</span>
    </div>

    <div id="match-content">
      <!-- Populated by JS -->
    </div>

    <div id="match-not-found" style="display:none;">
      Match not found. <a href="/l1/scoretap/" style="color:var(--accent);">Return to scores</a>
    </div>
  </div>

  <script is:inline>
    var matchData = {
