          { name: 'TenZ',    team: 'SEN',  kills: 22, deaths: 14, assists: 4,  rating: '1.38', hs: '61%' },
          { name: 'zekken',  team: 'SEN',  kills: 18, deaths: 16, assists: 7,  rating: '1.09', hs: '44%' },
          { name: 'bang',    team: 'SEN',  kills: 14, deaths: 15, assists: 12, rating: '0.97', hs: '29%' },
          { name: 'aspas',   team: 'LOUD', kills: 20, deaths: 17, assists: 5,  rating: '1.15', hs: '55%' },
          { name: 'saadhak', team: 'LOUD', kills: 12, deaths: 16, assists: 14, rating: '0.88', hs: '22%' },
          { name: 'Less',    team: 'LOUD', kills: 16, deaths: 18, assists: 8,  rating: '0.93', hs: '38%' }
        ],
