    var TEAM_SLUGS = {
      'Vitality': 'vitality', 'NAVI': 'navi', 'G2': 'g2', 'MOUZ': 'mouz',
      'Sentinels': 'sentinels', 'Paper Rex': 'paper-rex', 'NRG': 'nrg',
      'T1': 't1', 'Gen.G': 'gen-g', 'G2 Esports': 'g2-lol',
      'Team Spirit': 'spirit', 'OG': 'og',
      'Team BDS': 'bds', 'Team Liquid': 'liquid', 'Cloud9': 'cloud9'
    };
    function teamLink(name) {
      var slug = TEAM_SLUGS[name];
      if (slug) return '<a href="/l1/scoretap/team?id=' + slug + '" style="color:inherit;">' + name + '</a>';
      return name;
    }

    function buildEventPage(ev) {
      document.title = ev.name + ' — ScoreTap';
      document.getElementById('breadcrumb-event').textContent = ev.name;

      var gameTagHtml = '<span class="game-tag ' + ev.game + '">' + ev.gameLabel + '</span>';
      var statusClass = ev.status === 'live' ? 'live' : (ev.status === 'completed' ? 'final' : 'upcoming');
      var statusLabel = ev.status === 'live' ? 'Live' : (ev.status === 'completed' ? 'Completed' : 'Upcoming');
      var badgeHtml = '<span class="event-badge ' + statusClass + '">' + statusLabel + '</span>';

      var progressPct = ev.status === 'completed' ? 100 : (ev.status === 'upcoming' ? 0 : 65);
      // Calculate progress from stages if live
      if (ev.status === 'live' && ev.format && ev.format.stages) {
        var totalStages = ev.format.stages.length;
        var doneStages = 0;
        var liveStage = -1;
        for (var si = 0; si < totalStages; si++) {
          if (ev.format.stages[si].status === 'done') doneStages++;
          if (ev.format.stages[si].status === 'live') liveStage = si;
        }
        if (liveStage >= 0) {
          progressPct = Math.round(((doneStages + 0.5) / totalStages) * 100);
        }
      }
      var progressClass = ev.status === 'upcoming' ? ' upcoming' : (ev.status === 'completed' ? ' done' : '');

      // Header card
      var html =
        '<div class="event-header-card">' +
          '<div class="event-header-top">' + gameTagHtml + ' ' + badgeHtml + '</div>' +
          '<div class="event-name-display">' + ev.name + '</div>' +
          '<div class="event-info-row">' +
            '<span>&#128197; ' + ev.dates + '</span>' +
            '<span>&#128205; ' + ev.location + '</span>' +
            '<span class="prize-value">&#127942; ' + ev.prizePool + '</span>' +
            '<span>Organized by ' + ev.organizer + '</span>' +
          '</div>' +
          '<div class="event-progress-bar"><div class="event-progress-bar-fill' + progressClass + '" style="width:' + progressPct + '%"></div></div>' +
          (ev.statusNote ? '<div style="text-align:center;font-size:10px;color:var(--text-dim);margin-top:6px;text-transform:uppercase;letter-spacing:1px;">' + ev.statusNote + '</div>' : '') +
        '</div>';

      // Format & Structure
      if (ev.format) {
        var stageRows = ev.format.stages.map(function(s) {
          var stageStatusClass = s.status === 'live' ? 'stage-live' : (s.status === 'done' ? 'stage-done' : 'stage-upcoming');
          var stageLabel = s.status === 'live' ? 'LIVE' : (s.status === 'done' ? 'Completed' : 'Upcoming');
          return '<tr>' +
            '<td style="font-weight:700;color:var(--text-bright);">' + s.name + '</td>' +
            '<td>' + s.format + '</td>' +
            '<td style="text-align:center;">' + s.teams + '</td>' +
            '<td class="' + stageStatusClass + '">' + stageLabel + '</td>' +
          '</tr>';
        }).join('');

        html +=
          '<div class="widget">' +
            '<div class="widget-header"><span class="widget-title">&#9632; Format &amp; Structure</span></div>' +
            '<div style="padding:8px 10px;font-size:11px;color:var(--text);background:var(--bg-panel);border-bottom:1px solid var(--border);">' + ev.format.overview + '</div>' +
            '<table>' +
              '<thead><tr><th>Stage</th><th>Format</th><th>Teams</th><th>Status</th></tr></thead>' +
              '<tbody>' + stageRows + '</tbody>' +
            '</table>' +
          '</div>';
      }

      // Notable Matches
      if (ev.matches && ev.matches.length > 0) {
        var matchRows = ev.matches.map(function(m) {
          var isLinkable = m.matchId ? true : false;
          var trClass = isLinkable ? ' class="match-row-link"' : '';
          var trClick = isLinkable ? ' onclick="window.location.href=\'/l1/scoretap/match?id=' + m.matchId + '\'"' : '';
          var statusStyle = m.status === 'Live' ? 'color:var(--green);font-weight:700;' : (m.status === 'Upcoming' ? 'color:#606070;' : 'color:var(--text-dim);');
          return '<tr' + trClass + trClick + '>' +
            '<td style="font-weight:700;color:var(--text-bright);">' + teamLink(m.team1) + '</td>' +
            '<td style="text-align:center;font-weight:900;font-family:\'Courier New\',monospace;color:var(--accent);">' + m.score + '</td>' +
            '<td style="font-weight:700;color:var(--text-bright);text-align:right;">' + teamLink(m.team2) + '</td>' +
            '<td style="color:var(--text-dim);font-size:10px;">' + m.stage + '</td>' +
            '<td style="' + statusStyle + 'font-size:10px;">' + m.status + (isLinkable ? ' &#8250;' : '') + '</td>' +
          '</tr>';
        }).join('');

        html +=
          '<div class="widget">' +
            '<div class="widget-header"><span class="widget-title">&#9632; Notable Matches</span></div>' +
            '<table>' +
              '<thead><tr><th>Team 1</th><th>Score</th><th style="text-align:right;">Team 2</th><th>Stage</th><th>Status</th></tr></thead>' +
              '<tbody>' + matchRows + '</tbody>' +
            '</table>' +
          '</div>';
      }

      // Participating Teams
      if (ev.teams && ev.teams.length > 0) {
        var teamRows = ev.teams.map(function(t) {
          var elimClass = (t.status === 'eliminated') ? ' class="team-eliminated"' : '';
          var statusText = t.status === 'champion' ? 'Champion' : (t.status === 'runner-up' ? 'Runner-up' : (t.status === 'eliminated' ? 'Eliminated' : 'Active'));
          var statusColor = t.status === 'champion' ? 'color:var(--accent);font-weight:700;' : (t.status === 'runner-up' ? 'color:var(--text-bright);' : (t.status === 'eliminated' ? 'color:#505060;' : 'color:var(--green);'));
          return '<tr>' +
            '<td style="text-align:center;font-weight:700;color:var(--text-dim);">' + t.seed + '</td>' +
            '<td style="font-weight:700;color:var(--text-bright);"' + elimClass + '>' + teamLink(t.name) + '</td>' +
            '<td style="color:var(--text-dim);">' + t.region + '</td>' +
            '<td style="' + statusColor + '">' + statusText + '</td>' +
          '</tr>';
        }).join('');

        html +=
          '<div class="widget">' +
            '<div class="widget-header"><span class="widget-title">&#9632; Participating Teams</span><span class="widget-link">' + ev.teams.length + ' teams</span></div>' +
            '<table>' +
              '<thead><tr><th>Seed</th><th>Team</th><th>Region</th><th>Status</th></tr></thead>' +
              '<tbody>' + teamRows + '</tbody>' +
            '</table>' +
          '</div>';
      }

      // Prize Distribution
      if (ev.prizes && ev.prizes.length > 0) {
        var prizeRows = ev.prizes.map(function(p, i) {
          var rowClass = i === 0 ? ' class="prize-first"' : '';
          return '<tr' + rowClass + '>' +
            '<td style="font-weight:700;">' + p.place + '</td>' +
            '<td class="prize-amount">' + p.prize + '</td>' +
            '<td style="color:var(--text-dim);">' + p.team + '</td>' +
          '</tr>';
        }).join('');

        html +=
          '<div class="widget">' +
            '<div class="widget-header"><span class="widget-title">&#9632; Prize Distribution</span><span class="widget-link">' + ev.prizePool + ' total</span></div>' +
            '<table>' +
              '<thead><tr><th>Place</th><th>Prize</th><th>Team</th></tr></thead>' +
              '<tbody>' + prizeRows + '</tbody>' +
            '</table>' +
          '</div>';
      }

      // Related News
      if (ev.news && ev.news.length > 0) {
        var newsItems = ev.news.map(function(n) {
          return '<li><a href="' + n.href + '">' + n.headline + '</a><div class="news-meta-small">' + n.time + '</div></li>';
        }).join('');

        html +=
          '<div class="widget">' +
            '<div class="widget-header"><span class="widget-title">&#9632; Related News</span><a class="widget-link" href="/l1/scoretap/news">All News</a></div>' +
            '<ul class="news-list">' + newsItems + '</ul>' +
          '</div>';
      }

      document.getElementById('event-content').innerHTML = html;
    }

    var params = new URLSearchParams(window.location.search);
    var eventId = params.get('id');
    var ev = eventId ? EVENTS[eventId] : null;

    if (ev) {
      buildEventPage(ev);
    } else {
      document.getElementById('event-not-found').style.display = 'block';
    }
  </script>

