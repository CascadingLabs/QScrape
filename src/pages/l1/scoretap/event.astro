<SiteShell title="Event Details — ScoreTap" activePage="events">

  <style>
    .event-detail-container {
      max-width: 1100px;
      margin: 14px auto;
      padding: 0 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .event-header-card {
      background: linear-gradient(180deg, #181828 0%, var(--bg-panel) 100%);
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      padding: 20px;
      text-align: center;
    }
    .event-header-top {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-bottom: 12px;
    }
    .event-name-display {
      font-size: 1.6rem;
      font-weight: 900;
      color: var(--text-bright);
      text-transform: uppercase;
      letter-spacing: 1px;
      line-height: 1.2;
      margin-bottom: 10px;
    }
    .event-info-row {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      font-size: 11px;
      color: var(--text-dim);
      flex-wrap: wrap;
    }
    .event-info-row span { display: flex; align-items: center; gap: 4px; }
    .event-info-row .prize-value {
      color: var(--green);
      font-weight: 700;
      font-family: 'Courier New', monospace;
      font-size: 12px;
    }

    .event-progress-bar {
      height: 4px;
      background: #1c1c2c;
      margin-top: 14px;
      position: relative;
      overflow: hidden;
    }
    .event-progress-bar-fill {
      height: 100%;
      background: var(--accent);
    }
    .event-progress-bar-fill.upcoming { background: #404058; }
    .event-progress-bar-fill.done { background: #303044; }

    /* stage status badges */
    .stage-live {
      color: var(--green);
      font-weight: 700;
    }
    .stage-done {
      color: var(--text-dim);
    }
    .stage-upcoming {
      color: #606070;
    }

    /* team eliminated */
    .team-eliminated {
      color: #505060 !important;
      text-decoration: line-through;
    }

    /* prize styling */
    .prize-first td:first-child {
      color: var(--accent);
      font-weight: 700;
    }
    .prize-amount {
      color: var(--green);
      font-weight: 700;
      font-family: 'Courier New', monospace;
    }

    .match-row-link {
      cursor: pointer;
    }
    .match-row-link:hover td {
      background: #1e1e30 !important;
    }

    #event-not-found {
      text-align: center;
      padding: 40px;
      color: var(--text-dim);
      font-size: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-panel);
    }
  </style>

  <div class="event-detail-container">
    <div class="breadcrumb">
      <a href="/l1/scoretap/">Home</a> &rsaquo;
      <a href="/l1/scoretap/events">Events</a> &rsaquo;
      <span id="breadcrumb-event">Event Detail</span>
    </div>

    <div id="event-content">
      <!-- Populated by JS -->
    </div>

    <div id="event-not-found" style="display:none;">
      Event not found. <a href="/l1/scoretap/events" style="color:var(--accent);">Return to events</a>
    </div>
  </div>

