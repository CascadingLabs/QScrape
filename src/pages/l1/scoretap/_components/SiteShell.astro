---
interface Props {
	title: string;
	activePage?: string;
}
const { title, activePage } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <style is:global>
    :root {
      --bg:            #111116;
      --bg-panel:      #1a1a24;
      --bg-header:     #0c0c14;
      --bg-row-alt:    #15151f;
      --border:        #252535;
      --border-accent: #ff6b00;
      --text:          #c0c0cc;
      --text-dim:      #80808e;
      --text-bright:   #e8e8f0;
      --accent:        #ff6b00;
      --green:         #1fc45a;
      --red:           #cc2222;
      --font:          Tahoma, Verdana, Arial, sans-serif;
      --font-size:     12px;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      border-radius: 0 !important;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: var(--font-size);
      line-height: 1.4;
    }

    a { color: inherit; text-decoration: none; }

    /* ── UTILITY BAR ── */
    #utility-bar {
      background: #08080e;
      border-bottom: 1px solid var(--border);
      padding: 4px 12px;
      font-size: 11px;
      color: var(--text-dim);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .util-links { display: flex; }
    .util-links a {
      color: #666676;
      padding: 0 10px;
      border-left: 1px solid #1c1c2c;
      font-size: 11px;
      cursor: pointer;
      position: relative;
    }
    .util-links a:hover { color: var(--accent); }

    .live-dot {
      display: inline-block;
      width: 7px; height: 7px;
      background: #dd2222;
      border-radius: 50% !important;
      margin-right: 5px;
      animation: pulse 1.5s ease-in-out infinite;
      vertical-align: middle;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    /* ── PURE JS TOOLTIP ── */
    .js-tooltip {
      display: none;
      position: absolute;
      bottom: calc(100% + 6px);
      left: 50%;
      transform: translateX(-50%);
      background: #20202e;
      border: 1px solid var(--border);
      color: var(--text);
      font: 10px var(--font);
      padding: 4px 8px;
      white-space: nowrap;
      z-index: 1000;
      pointer-events: none;
    }
    .js-tooltip-visible { display: block; }

    /* ── HEADER ── */
    #site-header {
      background: linear-gradient(180deg, #12121e 0%, #0c0c14 100%);
      border-bottom: 3px solid var(--accent);
      padding: 10px 12px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .logo-block { display: flex; flex-direction: column; gap: 1px; }
    .logo {
      font-size: 1.8rem;
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: -1px;
      line-height: 1;
    }
    .logo span { color: var(--accent); }
    .logo-tagline {
      font-size: 9px;
      font-weight: 700;
      color: #585870;
      text-transform: uppercase;
      letter-spacing: 3px;
    }
    #search-input {
      background: #0a0a12;
      border: 1px solid var(--border);
      color: #888;
      font: 11px var(--font);
      padding: 5px 8px;
      flex: 1;
      max-width: 360px;
      outline: none;
    }
    #search-input:focus { border-color: var(--border); outline: none; }
    #search-input::placeholder { color: #404058; }
    #search-input[readonly] { cursor: not-allowed; opacity: 0.5; }
    .header-date {
      margin-left: auto;
      font-size: 10px;
      color: #505065;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* ── MAIN NAV ── */
    #main-nav {
      background: var(--bg-header);
      border-bottom: 2px solid var(--accent);
      display: flex;
    }
    .nav-link {
      color: #8888a0;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 9px 16px;
      border-right: 1px solid #1a1a28;
      display: block;
    }
    .nav-link:first-child { border-left: 1px solid #1a1a28; }
    .nav-link:hover { color: #fff; background: var(--accent); }
    .nav-link.active { color: #fff; background: #7a3200; }

    /* ── GAME FILTER TABS ── */
    #game-filter {
      background: var(--bg-header);
      border-bottom: 1px solid var(--border);
      padding: 5px 8px;
    }
    .game-tab {
      border: 1px solid #1a1a28;
      border-top-color: #2a2a3a;
      border-left-color: #2a2a3a;
      border-bottom-color: #080810;
      border-right-color: #080810;
      background: #12121c;
      color: #666676;
      font: bold 10px var(--font);
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 4px 12px;
      margin-right: 3px;
      cursor: pointer;
    }
    .game-tab:hover { color: #888; background: #18182a; }
    .game-tab.active {
      background: #0c0c16;
      color: var(--accent);
      border-top-color: var(--accent);
      border-left-color: var(--accent);
      border-bottom-color: #06060e;
      border-right-color: #06060e;
    }

    /* ── WIDGET ── */
    .widget {
      background: var(--bg-panel);
      border: 1px solid var(--border);
      margin-bottom: 10px;
    }
    .widget-header {
      background: #1e1e2c;
      border-bottom: 2px solid var(--accent);
      padding: 5px 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .widget-title {
      font: bold 10px/1 var(--font);
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--accent);
    }
    .widget-link {
      font-size: 10px;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .widget-link:hover { color: var(--accent); }

    /* ── MATCH CARDS ── */
    .match-card {
      border-bottom: 1px solid var(--border);
      padding: 8px 10px;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 8px;
      color: inherit;
      cursor: pointer;
    }
    .match-card:hover { background: #131320; }
    .match-card:last-of-type { border-bottom: none; }
    .match-card.live { border-left: 3px solid var(--accent); }
    .match-card.live:hover { background: #141210; }

    .team-side { display: flex; flex-direction: column; gap: 2px; }
    .team-side.right { align-items: flex-end; }
    .team-name {
      font-size: 12px;
      font-weight: 700;
      color: var(--text-bright);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .team-abbr { font-size: 10px; color: var(--text-dim); }

    .score-block { text-align: center; min-width: 90px; }
    .score-numbers {
      font-size: 1.4rem;
      font-weight: 900;
      color: #888898;
      letter-spacing: 3px;
      font-family: 'Courier New', monospace;
    }
    .score-numbers.live-score { color: var(--accent); }
    .match-meta { font-size: 10px; color: var(--text-dim); margin-top: 2px; }
    .match-event { font-size: 10px; color: #666676; margin-top: 1px; }

    /* ── BADGES ── */
    .event-badge {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 1px;
      border: 1px solid;
    }
    .event-badge.live     { color: var(--green); border-color: #1fc45a40; background: #1fc45a0e; }
    .event-badge.upcoming { color: #787888;      border-color: #30303040; background: #10101010; }
    .event-badge.final    { color: #626272;      border-color: #20202040; background: #0a0a0a10; }

    .game-tag {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      padding: 1px 5px;
      text-transform: uppercase;
      letter-spacing: 1px;
      border: 1px solid;
    }
    .game-tag.cs2      { color: var(--accent); border-color: #ff6b0050; background: #ff6b000e; }
    .game-tag.valorant { color: #c084fc;       border-color: #c084fc50; background: #c084fc0e; }
    .game-tag.lol      { color: #60a5fa;       border-color: #60a5fa50; background: #60a5fa0e; }
    .game-tag.dota2    { color: #f87171;       border-color: #f8717150; background: #f871710e; }
    .game-tag.rl       { color: #34d399;       border-color: #34d39950; background: #34d3990e; }

    /* ── RESULTS ── */
    .result-winner { color: var(--green) !important; }
    .result-loser  { color: #303040 !important; }

    /* ── NEWS ── */
    .news-grid { display: grid; grid-template-columns: 1fr 1fr; }
    .news-card {
      padding: 10px;
      border-bottom: 1px solid var(--border);
      border-right: 1px solid var(--border);
    }
    .news-card:nth-child(even) { border-right: none; }
    .news-card:hover { background: #131320; }
    .news-headline {
      font-size: 11px;
      font-weight: 600;
      color: #c4c4d0;
      line-height: 1.4;
      margin-bottom: 5px;
      display: block;
    }
    .news-headline:hover { color: var(--accent); }
    .news-meta { font-size: 10px; color: var(--text-dim); display: flex; gap: 6px; align-items: center; }

    /* ── RANKINGS ── */
    .rank-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 10px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
    }
    .rank-row:nth-child(odd)  { background: var(--bg-panel); }
    .rank-row:nth-child(even) { background: var(--bg-row-alt); }
    .rank-row:last-child { border-bottom: none; }
    .rank-num    { width: 24px; color: var(--text-dim); font-weight: 700; font-size: 11px; }
    .rank-team   { flex: 1; color: var(--text-bright); font-weight: 700; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
    .rank-points { font-size: 10px; color: var(--text-dim); }
    .rank-change       { font-size: 10px; font-weight: 700; width: 26px; text-align: right; }
    .rank-change.up    { color: var(--green); }
    .rank-change.down  { color: var(--red); }
    .rank-change.same  { color: #5a5a70; }

    /* ── UPCOMING ── */
    .upcoming-card {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 10px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
    }
    .upcoming-card:last-child { border-bottom: none; }
    .upcoming-card:hover { background: #131320; }
    .upcoming-teams { font-weight: 700; color: var(--text-bright); text-transform: uppercase; font-size: 11px; letter-spacing: 0.3px; }
    .upcoming-time  { font-size: 10px; color: var(--text-dim); text-align: right; }

    /* ── EVENTS ── */
    .event-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 10px;
      border-bottom: 1px solid var(--border);
    }
    .event-row:last-child { border-bottom: none; }
    .event-row:hover { background: #131320; }
    .event-name  { flex: 1; font-size: 11px; font-weight: 700; color: var(--text); text-transform: uppercase; letter-spacing: 0.3px; }
    .event-dates { font-size: 10px; color: var(--text-dim); }

    /* ── TABLES ── */
    table { border-collapse: collapse; width: 100%; }
    td, th {
      border: 1px solid var(--border);
      padding: 4px 8px;
      font-size: 11px;
      font-family: var(--font);
    }
    th {
      background: #16162a;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-size: 10px;
      font-weight: 700;
    }
    tbody tr:nth-child(odd)  { background: var(--bg-panel); }
    tbody tr:nth-child(even) { background: var(--bg-row-alt); }
    tbody tr:hover { background: #1e1e30; }

    /* ── LAYOUT ── */
    .page-layout {
      display: grid;
      grid-template-columns: 1fr 320px;
      gap: 10px;
      max-width: 1280px;
      margin: 10px auto;
      padding: 0 10px;
    }
    .main-col { min-width: 0; }
    .sidebar   { min-width: 0; }

    /* ── MATCH DETAIL ── */
    .match-detail-container {
      max-width: 1100px;
      margin: 14px auto;
      padding: 0 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .breadcrumb { font-size: 11px; color: var(--text-dim); padding: 4px 0; }
    .breadcrumb a { color: var(--accent); }
    .breadcrumb a:hover { text-decoration: underline; }

    .match-header-card {
      background: linear-gradient(180deg, #181828 0%, var(--bg-panel) 100%);
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      padding: 20px;
    }
    .match-event-info {
      font-size: 10px;
      color: var(--text-dim);
      text-align: center;
      margin-bottom: 16px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .match-event-info span { color: var(--accent); }

    .teams-row {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 16px;
    }
    .team-block { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .team-logo-placeholder {
      width: 60px;
      height: 60px;
      background: #10101c;
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 900;
      color: var(--accent);
    }
    .team-full-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text-bright);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .team-region { font-size: 10px; color: var(--text-dim); }

    .score-center { text-align: center; }
    .main-score {
      font-size: 2.5rem;
      font-weight: 900;
      letter-spacing: 4px;
      color: var(--accent);
      line-height: 1;
      font-family: 'Courier New', monospace;
    }
    .score-status {
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 6px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .live-pill {
      display: inline-block;
      background: #cc222210;
      color: var(--red);
      border: 1px solid #cc222240;
      padding: 1px 6px;
      font-size: 9px;
      font-weight: 700;
    }

    .stat-highlight { font-weight: 700; }
    .rating-high { color: var(--green); font-weight: 700; }
    .rating-mid  { color: #c87800; }
    .rating-low  { color: var(--red); }
    .td-win  { color: var(--green); font-weight: 700; }
    .td-loss { color: var(--red); }
    .td-map  { font-weight: 700; color: var(--text-bright); }

    .news-list { list-style: none; }
    .news-list li {
      padding: 8px 10px;
      border-bottom: 1px solid var(--border);
      font-size: 11px;
    }
    .news-list li:nth-child(odd)  { background: var(--bg-panel); }
    .news-list li:nth-child(even) { background: var(--bg-row-alt); }
    .news-list li:last-child { border-bottom: none; }
    .news-list a { color: var(--text); }
    .news-list a:hover { color: var(--accent); }
    .news-meta-small { font-size: 10px; color: var(--text-dim); margin-top: 2px; }

    #match-not-found {
      text-align: center;
      padding: 40px;
      color: var(--text-dim);
      font-size: 1rem;
      border: 1px solid var(--border);
      background: var(--bg-panel);
    }

    /* ── FOOTER ── */
    #site-footer {
      background: #08080e;
      border-top: 2px solid var(--border);
      padding: 14px 12px;
      margin-top: 14px;
      font-size: 11px;
      color: #55556a;
      text-align: center;
    }
    #site-footer a { color: #55556a; margin: 0 8px; }
    #site-footer a:hover { color: var(--accent); }
    .footer-logo {
      color: var(--text-bright);
      font-weight: 900;
      font-size: 1.1rem;
      letter-spacing: -0.5px;
      margin-bottom: 5px;
    }
    .footer-logo span { color: var(--accent); }
  </style>
</head>
<body>

  <header style="position:sticky;top:0;z-index:200;">
  <!-- Utility bar -->
  <div id="utility-bar">
    <span>
      <span class="live-dot"></span>
      <span id="live-count" style="color:#8888a0;">3 MATCHES LIVE NOW</span>
    </span>
    <span class="util-links">
      <a href="#" tabindex="-1" data-tooltip="Level 1 doesn't have sign in, register or settings options">Sign In</a>
      <a href="#" tabindex="-1" data-tooltip="Level 1 doesn't have sign in, register or settings options">Register</a>
      <a href="#" tabindex="-1" data-tooltip="Level 1 doesn't have sign in, register or settings options">Settings</a>
    </span>
  </div>

  <!-- Header -->
  <div id="site-header">
    <a class="logo-block" href="/l1/scoretap/">
      <span class="logo">🎯 Score<span>Tap</span></span>
      <span class="logo-tagline">Scores. Stats. Now.</span>
    </a>
    <div style="position:relative; flex:1; max-width:360px;" data-tooltip="Level 1 doesn't have search options">
      <input id="search-input" type="text" placeholder="Search teams, players, events..." style="width:100%;cursor:not-allowed;" readonly>
    </div>
    <span class="header-date">Wed Mar 11 2026</span>
  </div>

  <!-- Main nav -->
  <div id="main-nav">
    <a class:list={["nav-link", { active: activePage === 'scores' || !activePage }]} href="/l1/scoretap/">Scores</a>
    <a class:list={["nav-link", { active: activePage === 'news' }]} href="/l1/scoretap/news">News</a>
    <a class:list={["nav-link", { active: activePage === 'teams' }]} href="/l1/scoretap/teams">Teams</a>
    <a class:list={["nav-link", { active: activePage === 'events' }]} href="/l1/scoretap/events">Events</a>
  </div>
  </header>

  <slot />

  <!-- Footer -->
  <div id="site-footer">
    <div class="footer-logo">Score<span>Tap</span></div>
    <div>&copy; 2026 ScoreTap Media. All rights reserved.</div>
    <div style="margin-top:5px;">
      <a href="#">About</a>
      <a href="#">Contact</a>
      <a href="#">Privacy</a>
      <a href="#">Terms</a>
      <a href="#">Advertise</a>
      <a href="#">API</a>
    </div>
  </div>

  <script is:inline>
    // Pure JS tooltip
    document.querySelectorAll('[data-tooltip]').forEach(function(el) {
      var box = document.createElement('span');
      box.className = 'js-tooltip';
      box.textContent = el.getAttribute('data-tooltip');
      el.appendChild(box);
      el.addEventListener('mouseenter', function() { box.classList.add('js-tooltip-visible'); });
      el.addEventListener('mouseleave', function() { box.classList.remove('js-tooltip-visible'); });
      el.addEventListener('focus',      function() { box.classList.add('js-tooltip-visible'); });
      el.addEventListener('blur',       function() { box.classList.remove('js-tooltip-visible'); });
    });
  </script>
</body>
</html>
