<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BetLines - Sports Betting Odds</title>
    <meta name="description" content="Live sports betting odds, spreads, and lines for NBA, NFL, NHL, and more.">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a1a;
        }
        
        header {
            background: linear-gradient(135deg, #1f2937 0%, #111827 100%);
            padding: 20px 40px;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .header-content {
            max-width: 1000px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        header h1 {
            color: #fbbf24;
            font-size: 1.5rem;
            font-weight: 800;
        }
        
        header h1 span { color: #fff; }
        
        nav a {
            color: #9ca3af;
            text-decoration: none;
            margin-left: 25px;
            font-size: 14px;
        }
        
        nav a:hover { color: #fbbf24; }
        
        .banner {
            background: linear-gradient(90deg, #fbbf24, #f59e0b);
            color: #000;
            text-align: center;
            padding: 12px;
            font-weight: 600;
            font-size: 14px;
        }
        
        .odds-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 30px 20px;
        }
        
        .page-title {
            color: #fff;
            font-size: 28px;
            margin-bottom: 20px;
            text-align: center;
        }
        
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
        
        .sport-filter {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }
        
        .sport-filter button {
            background: #374151;
            color: #d1d5db;
            border: none;
            padding: 12px 24px;
            border-radius: 25px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s;
        }
        
        .sport-filter button:hover, .sport-filter button.active {
            background: #fbbf24;
            color: #000;
        }
        
        .games-table {
            width: 100%;
            border-collapse: collapse;
            background: #242424;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        
        .games-table tbody tr { border-bottom: 1px solid #333; }
        
        .games-table tbody tr:nth-child(4n+1), .games-table tbody tr:nth-child(4n+2) { background: #2a2a2a; }
        .games-table tbody tr:nth-child(4n+3), .games-table tbody tr:nth-child(4n) { background: #242424; }
        .games-table tbody tr:hover { background: #333 !important; }
        
        .games-table td { padding: 16px 20px; vertical-align: middle; }
        
        .games-table td:first-child {
            width: 130px;
            text-align: center;
            background: #1f1f1f !important;
            border-right: 1px solid #333;
        }
        
        .game-time {
            font-family: 'Courier New', monospace;
            font-size: 14px;
            color: #fbbf24;
            font-weight: 600;
        }
        
        .game-time .live {
            display: inline-block;
            background: #dc2626;
            color: #fff;
            font-size: 9px;
            padding: 2px 6px;
            border-radius: 8px;
            margin-left: 5px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        
        .team {
            font-size: 16px;
            color: #fff;
            font-weight: 500;
            display: block;
            margin-bottom: 4px;
        }
        
        .odds {
            font-family: 'Courier New', monospace;
            font-size: 18px;
            font-weight: 700;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 6px;
            min-width: 70px;
            text-align: center;
        }
        
        .odds-positive { background: #166534; color: #4ade80; }
        .odds-negative { background: #991b1b; color: #f87171; }
        
        .game-row { display: flex; justify-content: space-between; align-items: center; }
        .game-row .team-column { flex: 1; }
        .game-row .odds-column { width: 100px; text-align: right; }
        
        .section-title {
            color: #fff;
            font-size: 18px;
            margin: 30px 0 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #fbbf24;
        }
        
        .betting-tools {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-top: 30px;
        }
        
        .tool-card {
            background: #242424;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }
        
        .tool-card h3 { color: #fbbf24; font-size: 16px; margin-bottom: 10px; }
        .tool-card p { color: #9ca3af; font-size: 13px; }
        
        .disclaimer {
            text-align: center;
            color: #666;
            font-size: 12px;
            margin-top: 30px;
            padding: 20px;
            background: #242424;
            border-radius: 8px;
        }
        
        footer {
            background: #111827;
            color: #6b7280;
            padding: 30px;
            text-align: center;
            font-size: 12px;
            margin-top: 40px;
        }
        
        footer a { color: #9ca3af; text-decoration: none; margin: 0 10px; }
    </style>
</head>
<body>
