---
import AdUnit from './_components/AdUnit.astro';
import HeraldShell from './_components/HeraldShell.astro';

const postData = Astro.url.searchParams.get('postData') || '';
---

<HeraldShell title="Article" breadcrumbs={[{ label: 'Home', href: '/l1/news/' }, { label: 'Articles', href: '/l1/news/articles' }, { label: 'Loading...' }]}>

  <div class="pageTitle" id="articleTitle">Loading article...</div>

  <div class="formSection">
    <table class="aspNetTable articleMeta" style="width:100%;">
      <tr>
        <td style="width:140px;"><span class="aspNetLabelBold">Article ID:</span></td>
        <td id="lblId">-</td>
      </tr>
      <tr class="alternatingRow">
        <td><span class="aspNetLabelBold">Category:</span></td>
        <td><span id="lblCategory">-</span></td>
      </tr>
      <tr>
        <td><span class="aspNetLabelBold">Published:</span></td>
        <td id="lblDate">-</td>
      </tr>
      <tr class="alternatingRow" id="rowUpdated" style="display:none;">
        <td><span class="aspNetLabelBold">Updated:</span></td>
        <td id="lblUpdated">-</td>
      </tr>
      <tr>
        <td><span class="aspNetLabelBold">Author:</span></td>
        <td id="lblAuthor">-</td>
      </tr>
      <tr class="alternatingRow">
        <td><span class="aspNetLabelBold">Byline:</span></td>
        <td id="lblByline">-</td>
      </tr>
      <tr>
        <td><span class="aspNetLabelBold">Tags:</span></td>
        <td id="lblTags" class="tagList">-</td>
      </tr>
    </table>
  </div>

  <div class="articleImage" id="articleImage" style="display:none;">
    <img id="articleImg" src="" alt="" />
    <div class="imageCaption">
      <span id="imgCaption"></span>
      <span class="imageCredit" id="imgCredit"></span>
    </div>
  </div>

  <div class="articleBody" id="articleBody">
    <p>Loading article content...</p>
  </div>

  <!-- Mid-article ad -->
  <div class="adSlot--inline">
    <AdUnit size="banner" adId="DSN-BAN-002" text="Grand Duchy Museum &mdash; Forgotten Beast Collection Now Open" cta="Plan Your Visit" placement="article_mid" />
  </div>

  <div class="formSection" id="relatedSection">
    <strong>Related Articles</strong>
    <div class="relatedLinks" id="relatedLinks"></div>
  </div>

  <!-- Comments Section -->
  <div class="formSection" id="commentsSection">
    <strong>Reader Comments</strong>
    <p style="font-size:10px; color:#666; margin:4px 0 8px 0;">
      Comments are moderated by Herald editorial staff. Anonymous submissions from goblin sources are not published.
    </p>
    <div id="commentsList"></div>

    <div style="margin-top:12px; border-top:1px solid #ccc; padding-top:10px;">
      <strong style="font-size:11px;">Post a Comment</strong>
      <table class="aspNetTable" style="width:100%; margin-top:6px;">
        <tr>
          <td style="width:120px;"><span class="aspNetLabelBold">Name:</span></td>
          <td><input type="text" id="commentName" style="width:250px; font-family:Verdana,sans-serif; font-size:11px; border:1px solid #999; padding:2px;" /></td>
        </tr>
        <tr class="alternatingRow">
          <td><span class="aspNetLabelBold">Guild Affiliation:</span></td>
          <td><input type="text" id="commentGuild" style="width:250px; font-family:Verdana,sans-serif; font-size:11px; border:1px solid #999; padding:2px;" placeholder="Optional" /></td>
        </tr>
        <tr>
          <td style="vertical-align:top;"><span class="aspNetLabelBold">Comment:</span></td>
          <td><textarea id="commentText" rows="4" style="width:400px; font-family:Verdana,sans-serif; font-size:11px; border:1px solid #999; padding:2px;"></textarea></td>
        </tr>
        <tr class="alternatingRow">
          <td></td>
          <td>
            <button class="aspNetButton" onclick="alert('Thank you for your comment. All submissions are reviewed by Herald editorial staff before publication. Expect moderation within 1-2 business days.');">Submit Comment</button>
            <span style="font-size:9px; color:#999; margin-left:8px;">Max 200 runes. Dwarven Standard Script only.</span>
          </td>
        </tr>
      </table>
    </div>
  </div>

  <div class="formSection">
    <strong>Article Options</strong>
    <table style="margin:10px 0;">
      <tr>
        <td style="padding:5px;"><a href="javascript:window.print();" class="aspNetButton">Print Article</a></td>
        <td style="padding:5px;"><a href="/l1/news/articles" class="aspNetButton">Back to Articles</a></td>
        <td style="padding:5px;"><a href="/l1/news/" class="aspNetButton">Herald Home</a></td>
      </tr>
    </table>
  </div>

  <!-- JSON-LD Structured Data (populated client-side) -->
  <script type="application/ld+json" id="jsonLd">{}</script>

  <script is:inline>
  var ARTICLES = {
    'MHH-001': {
      id: 'MHH-001', category: 'Politics', published: '2026-01-01T08:15:00',
      headline: 'Arcane Council Votes 7-2 to Expand Magma Infrastructure Eastward',
      author: 'Urist McReporter', byline: 'Senior Correspondent, Politics Desk',
      tags: ['Arcane Council', 'Magma Infrastructure', 'East Expansion', 'Public Works'],
      image: 'https://picsum.photos/seed/mhh001/580/320',
      imageCaption: 'Council members deliberate in the Arcane Chamber during Thursday\'s vote on the Magma Infrastructure bill.',
      imageCredit: 'Herald Archive / Staff',
      body: [
        'MOUNTAINHOME \u2014 The Arcane Council voted 7-2 on Thursday to approve the Eastern Magma Infrastructure Expansion Act, authorising the Bureau of Deep Works to extend the main magma channel network an estimated 340 z-meters eastward into the previously undeveloped Granite Flats sector.',
        'The measure, which passed after three hours of debate, will fund construction of two new primary magma conduits, four secondary distribution channels, and an emergency containment station at Z-Level 80. Councillor Urist Stonesinger (Guild Ward) and Councillor Meng Doren (Residential Quarter) cast the dissenting votes, citing concerns about seismic risk in the Granite Flats and the absence of an independent geomantic survey.',
        '<div class="pullQuote">"The expansion is overdue. Twelve forges in the eastern quarter have been operating on auxiliary heat for two seasons. This is an economic necessity."<span class="attribution">\u2014 Council Chair Aban Copperhelm</span></div>',
        'Critics from the Residential Quarter Tenants\' Assembly argue that the council moved too quickly, pointing to the <a href="javascript:navigateToArticle(\'MHH-005\')">Geomancer\'s Office advisory issued last week</a> flagging elevated seismic readings at Z-Level 45 in the same general region.',
        'The Bureau of Deep Works estimates construction will take four seasons and cost approximately 14,000 Gold Sovereigns. A public comment period of 30 days is open for citizens wishing to submit objections. The Bureau\'s project office is located at Z-Level 3, Room 44. Related land records are available through the <a href="/l1/taxes/">Arcane Registry of Deeds</a>.',
        '<div class="infoBox"><div class="infoTitle">KEY FACTS</div><div class="infoContent"><strong>Vote:</strong> 7-2 in favour<br/><strong>Cost:</strong> ~14,000 Gold Sovereigns<br/><strong>Timeline:</strong> 4 seasons<br/><strong>Scope:</strong> 2 primary magma conduits, 4 secondary channels, 1 containment station<br/><strong>Public comment:</strong> 30-day period now open \u2014 Z-Level 3, Room 44</div></div>'
      ]
    },
    'MHH-002': {
      id: 'MHH-002', category: 'Crime', published: '2026-01-08T11:42:00',
      headline: 'Fortress Guard Arrest Three in Trophy Hall Gem-Skimming Scheme',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Crime Desk',
      tags: ['Fortress Guard', 'Gem Theft', 'Trophy Hall', 'Arrest'],
      image: 'https://picsum.photos/seed/mhh002/580/320',
      imageCaption: 'The Grand Trophy Hall on Z-Level 14, where investigators say at least 94 carats of gemstones were substituted over six months.',
      imageCredit: 'Fortress Guard / Public Affairs',
      body: [
        'MOUNTAINHOME \u2014 Fortress Guard officers arrested three dwarves late Wednesday in connection with an alleged gem-skimming operation at the Grand Trophy Hall on Z-Level 14, where an estimated 80 to 120 carats of raw emerald and sapphire material are believed to have been diverted over a period of six months.',
        'Those taken into custody were identified as Doren Stonepick, 44, a Trophy Hall maintenance worker; Rimtar Coalvein, 51, a licensed gem appraiser; and Aban Silkthread, 38, described by investigators as the alleged organiser of the scheme. All three were booked at the Z-Level 6 Guard Station and are being held pending a bond hearing scheduled for Friday.',
        'According to the Fortress Guard\'s preliminary account, the three allegedly exploited a gap in the Trophy Hall\'s gem inventory reconciliation process, substituting lower-quality stones in display cases while siphoning higher-grade material to a third-party buyer whose identity has not yet been disclosed.',
        '<div class="pullQuote">"The integrity of the Trophy Hall collection is a matter of civic pride. We take this extremely seriously."<span class="attribution">\u2014 Guard Captain Morul Axebearer</span></div>',
        'The Grand Trophy Hall, which houses the Grand Duchy\'s official collection of battle trophies, beast skulls, and commemorative gemstone awards, underwent a full inventory audit following a tip from an anonymous source. The audit identified 94 carats of suspected substitutions.',
        'Property records filed with the <a href="/l1/taxes/">Registry of Deeds</a> show that Aban Silkthread registered two new mineral storage leases in the Lower Bazaar district in the months coinciding with the alleged scheme, though investigators have not publicly linked the leases to the case.'
      ]
    },
    'MHH-003': {
      id: 'MHH-003', category: 'Economy', published: '2026-01-14T09:30:00',
      headline: 'Dwarven Iron Guild Reports Record Smelting Output for Fifth Consecutive Season',
      author: 'Rigoth Gemcutter', byline: 'Economics Correspondent',
      tags: ['Dwarven Iron Guild', 'Smelting', 'Production Record', 'Economy'],
      image: 'https://picsum.photos/seed/mhh003/580/320',
      imageCaption: 'Iron ingots stacked for transport at the Koganusan Processing Complex on Z-Level 72.',
      imageCredit: 'Dwarven Iron Guild / Press Office',
      body: [
        'MOUNTAINHOME \u2014 The Dwarven Iron Guild announced on Tuesday that its member forges collectively produced 48,200 iron ingots in the most recent smelting season, a 6.4 per cent increase over the prior season and the fifth consecutive record output.',
        'Guild Master Iden Ironclad attributed the sustained growth to expanded ore access following the opening of three new mining shafts in the Z-Level 60\u201380 corridor, efficiency improvements at the Koganusan Processing Complex, and a seasonal reduction in forge-disrupting cave-in incidents.',
        '<div class="pullQuote">"Five consecutive records is a milestone we are proud of. The eastern shaft network has proven more productive than initial surveys suggested."<span class="attribution">\u2014 Guild Master Iden Ironclad</span></div>',
        'The strong output has contributed to downward price pressure on standard iron bars on the Mountainhome open market, with the spot price falling from 12 GP per ingot to 10.5 GP since mid-Year 311. Smaller independent smiths have complained that Guild pricing advantages are squeezing their margins.',
        '<div class="infoBox"><div class="infoTitle">IRON MARKET SNAPSHOT</div><div class="infoContent"><strong>Season output:</strong> 48,200 ingots (+6.4%)<br/><strong>Consecutive records:</strong> 5 seasons<br/><strong>Spot price:</strong> 10.5 GP/ingot (down from 12 GP)<br/><strong>Guild wage:</strong> 3.2 GP/shift (highest in Duchy)<br/><strong>Source:</strong> <a href="/l1/taxes/">Registry of Deeds \u2014 commercial filings</a></div></div>',
        'The Guild dismissed margin concerns from independent smiths, saying market normalisation benefits consumers. The next quarterly output report is expected in late spring.'
      ]
    },
    'MHH-004': {
      id: 'MHH-004', category: 'Culture', published: '2026-01-20T19:15:00',
      headline: "Mountainhome Bard's Troupe Premieres 'The Ballad of Boatmurdered'",
      author: 'Fikod Silentstone', byline: 'Arts & Culture Reporter',
      tags: ['Bard Troupe', 'Boatmurdered', 'Theatre', 'Performance', 'Culture'],
      image: 'https://picsum.photos/seed/mhh004/580/320',
      imageCaption: 'The ensemble cast takes a curtain call after Monday\'s premiere at the Grand Amphitheatre.',
      imageCredit: 'Fikod Silentstone / Herald Arts',
      body: [
        'MOUNTAINHOME \u2014 The Mountainhome Bard\'s Troupe opened its new production, "The Ballad of Boatmurdered," at the Grand Amphitheatre on Z-Level 5 to a near-capacity audience on Monday evening, receiving extended applause from an audience estimated at 320 dwarves.',
        'The three-hour performance chronicles the legendary fall of Boatmurdered Fortress, incorporating recently declassified historical records from the Grand Duchy Archive. Lead performer Rigoth Silvervoice plays the doomed expedition overseer, with an ensemble of 14 portraying the ill-fated migrants, the goblin sieges, and the catastrophic elephant incursions that defined the fortress\'s final year.',
        '<div class="pullQuote">"Boatmurdered is not merely tragedy \u2014 it is instruction. We dig so that we may learn."<span class="attribution">\u2014 Troupe Director Fikod Oakcrown</span></div>',
        'Critical reception was largely positive. This reviewer found the second act \u2014 depicting the magma pump sabotage sequence \u2014 genuinely harrowing, and the stagecraft depicting the elephant stampede through the dining hall deserves special commendation. The <a href="javascript:navigateToArticle(\'MHH-010\')">Grand Duchy Museum\'s Forgotten Beast Collection</a>, which opened the following month, shares several archival sources with the production.',
        'The production runs through the end of the month. Tickets are available at the Amphitheatre box office (Z-Level 5, Room 2) for 4 GP general admission, 2 GP guild members. For more on Mountainhome\'s cultural calendar, see the <a href="/l1/news/about">Herald Arts desk</a>.'
      ]
    },
    'MHH-005': {
      id: 'MHH-005', category: 'Weather', published: '2026-01-23T14:08:00', updated: '2026-01-25T09:00:00',
      headline: "Geomancer's Office Issues Seismic Advisory for Z-Level 45",
      author: 'Zulban Tunnelworks', byline: 'Science Correspondent',
      tags: ['Geomancer', 'Seismic', 'Z-Level 45', 'Safety Advisory'],
      image: 'https://picsum.photos/seed/mhh005/580/320',
      imageCaption: 'Monitoring station 45-C, one of two stations that flagged anomalous tectonic stress readings.',
      imageCredit: 'Bureau of Deep Works',
      body: [
        'MOUNTAINHOME \u2014 The Geomancer\'s Office issued a formal Seismic Advisory on Wednesday covering Z-Level 45 and adjacent corridors, following detection of anomalous tectonic stress readings at monitoring stations 45-C and 45-D over the preceding five days.',
        'The advisory, rated Level 2 (Elevated Concern) on the five-tier Geomantic Hazard Scale, recommends that residents and workers in the affected zone limit non-essential foot traffic, that tunnel integrity inspections be expedited for any passage over 20 years old, and that heavy equipment operations be suspended pending further assessment.',
        '<div class="pullQuote">"The readings are not at a critical threshold, but the trend is unusual and warrants precautionary action."<span class="attribution">\u2014 Chief Geomancer Zulban Deepstone</span></div>',
        'Approximately 1,200 dwarves reside or work on Z-Level 45, including the Granite Flats Workshop District and two residential quarters. The Bureau of Deep Works confirmed it will dispatch structural assessment teams to the area by end of week. The advisory is particularly significant given the <a href="javascript:navigateToArticle(\'MHH-001\')">Arcane Council\'s recent vote to expand magma infrastructure</a> into the same general region.',
        '<div class="infoBox"><div class="infoTitle">GEOMANTIC HAZARD SCALE</div><div class="infoContent"><strong>Level 1:</strong> Normal Operations<br/><strong>Level 2:</strong> Elevated Concern \u2190 <em>Current</em><br/><strong>Level 3:</strong> Active Monitoring Required<br/><strong>Level 4:</strong> Partial Evacuation Recommended<br/><strong>Level 5:</strong> Full Evacuation Mandatory<br/><br/>Contact: Geomancer\'s Office, Z-Level 1, Room 8</div></div>',
        'The Geomancer\'s Office emphasized that no evacuation is currently recommended, but noted that the situation will be reassessed within seven days. Property owners in the advisory zone can verify their parcel records through the <a href="/l1/taxes/">Registry of Deeds portal</a>.'
      ]
    },
    'MHH-006': {
      id: 'MHH-006', category: 'Politics', published: '2026-02-02T10:22:00',
      headline: 'Goblin Diplomatic Envoy Expelled After Alleged Theft of Council Minutes',
      author: 'Urist McReporter', byline: 'Senior Correspondent, Politics Desk',
      tags: ['Goblin Diplomacy', 'Arcane Council', 'Espionage', 'Foreign Relations'],
      image: 'https://picsum.photos/seed/mhh006/580/320',
      imageCaption: 'The Upper Gate checkpoint where Fortress Guard inspectors intercepted the sealed documents.',
      imageCredit: 'Herald Staff',
      body: [
        'MOUNTAINHOME \u2014 The Grand Duchy expelled goblin diplomatic envoy Snatchtooth the Mild on Sunday after Fortress Guard investigators found copies of sealed Arcane Council session minutes in his diplomatic pouch during a routine inspection at the Upper Gate.',
        'The incident has significantly complicated ongoing truce negotiations between the Grand Duchy and the Goblin Confederation, which have been proceeding haltingly for the past two seasons under the auspices of the neutral Elven Mediation Council.',
        '<div class="pullQuote">"A deliberate and serious breach of diplomatic protocol."<span class="attribution">\u2014 Council Chair Aban Copperhelm</span></div>',
        'The Goblin Confederation\'s official response, transmitted via sending stone Tuesday morning, characterised Snatchtooth\'s expulsion as "unilateral and provocative" and denied that the envoy had engaged in any improper conduct, suggesting the inspection itself violated diplomatic immunity provisions.',
        'Legal scholars consulted by the Herald noted that the Grand Duchy\'s treaty with the Confederation contains no explicit diplomatic immunity clause, which the Confederation disputes. Truce talks are considered suspended indefinitely pending resolution of the dispute. The incident may also affect the <a href="javascript:navigateToArticle(\'MHH-016\')">Surface Relations Normalisation Act</a> currently before the Council.',
        'The expelled envoy\'s travel documents and registered lodging records have been filed with the <a href="/l1/taxes/">Registry of Deeds</a> as part of the investigation\'s public record. The Elven Mediation Council has not yet issued a statement.'
      ]
    },
    'MHH-007': {
      id: 'MHH-007', category: 'Sports', published: '2026-02-05T16:45:00',
      headline: 'Mountainhome Wrestlers Triumph at Z-Level Games',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Sports Desk',
      tags: ['Wrestling', 'Z-Level Games', 'Sports', 'Mountainhome'],
      image: 'https://picsum.photos/seed/mhh007/580/320',
      imageCaption: 'Avar Ironhand celebrates his twelfth Z-Level Games heavyweight victory at the Grand Arena.',
      imageCredit: 'Bomrek Hammerfall / Herald Sports',
      body: [
        'MOUNTAINHOME \u2014 The Mountainhome contingent swept four of six wrestling weight classes at the annual Z-Level Games held at the Grand Arena on Z-Level 8 over the weekend, with standout performances by veteran Avar Ironhand in the Heavyweight Division and rising competitor Dumed Stoneback in the Middleweight ranks.',
        'Ironhand, competing in his twelfth Z-Level Games, defeated challenger Morul Boulderarm of the Koganusan delegation in a best-of-three match that drew the largest crowd of the event \u2014 an estimated 540 spectators.',
        '<div class="pullQuote">"Avar is just something different. He reads his opponents better than anyone I have seen in thirty years of competition."<span class="attribution">\u2014 Team Captain Iden Hammerleg</span></div>',
        'Stoneback\'s Middleweight title was also notable, as the 23-year-old becomes the youngest Mountainhome champion in that division since Year 298. He defeated three opponents in the single-elimination bracket without conceding a fall. Follow the <a href="javascript:navigateToArticle(\'MHH-015\')">Fortress Wrestling League season opener</a> for Ironhand\'s continued title defence.',
        '<div class="infoBox"><div class="infoTitle">Z-LEVEL GAMES \u2014 RESULTS</div><div class="infoContent"><strong>Heavyweight Wrestling:</strong> Avar Ironhand (Mountainhome) def. Morul Boulderarm (Koganusan)<br/><strong>Middleweight Wrestling:</strong> Dumed Stoneback (Mountainhome), 3-0<br/><strong>Axe-Throwing:</strong> Mountainhome, 1st<br/><strong>Barrel-Rolling:</strong> Mountainhome, 1st<br/><strong>Deep-Mine Relay:</strong> Granite Flats, 1st; Mountainhome, 2nd<br/><br/>Full results: Grand Arena office, Z-Level 8, Room 1<br/>Live scores: <a href="/l1/scoretap/">ScoreTap</a></div></div>'
      ]
    },
    'MHH-008': {
      id: 'MHH-008', category: 'Crime', published: '2026-02-11T13:30:00',
      headline: 'Headshoots LLC Faces Civil Suit Over Catapult Safety Logs',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Crime Desk',
      tags: ['Headshoots LLC', 'Catapult', 'Civil Suit', 'Safety', 'Legal'],
      image: 'https://picsum.photos/seed/mhh008/580/320',
      imageCaption: 'The Eastern Rampart catapult battery, where the Year 311 malfunction injured five crew members.',
      imageCredit: 'Herald Archive',
      body: [
        'MOUNTAINHOME \u2014 Headshoots LLC, the fortress\'s largest siege equipment manufacturer and maintenance contractor, is facing a civil action filed in the Grand Duchy Circuit Court on behalf of five dwarves injured in a catapult malfunction at the Eastern Rampart in Year 311.',
        'The suit, brought by the law firm Stonecleave & Gemcutter, alleges that Headshoots LLC failed to maintain accurate safety inspection logs for the Eastern Rampart battery and that a routine inspection required under the Siege Equipment Safety Ordinance of Year 302 was not performed in the 18 months prior to the malfunction.',
        '<div class="pullQuote">"The inspection records speak for themselves \u2014 or rather, they do not exist, and that is precisely the problem."<span class="attribution">\u2014 Lead Counsel Rimtar Stonecleave</span></div>',
        'Headshoots LLC issued a statement denying the allegations, characterising the suit as "without merit" and asserting that all required inspections were performed, with records inadvertently misfiled during an office relocation in Year 310. The company\'s registration filings are on record at the <a href="/l1/taxes/">Arcane Registry of Deeds</a>.',
        'The malfunction in question involved the premature release of a counterweight during a live-fire exercise, injuring five members of the Rampart maintenance crew. Two of the five required extended care at the Fortress Infirmary. The case has been assigned to Circuit Judge Urist Hammerwright and a preliminary hearing is scheduled for the fourth week of next month.'
      ]
    },
    'MHH-009': {
      id: 'MHH-009', category: 'Economy', published: '2026-02-17T08:55:00',
      headline: 'Armok Holdings LLC Acquires Three Magma Sea Sector Parcels',
      author: 'Rigoth Gemcutter', byline: 'Economics Correspondent',
      tags: ['Armok Holdings', 'Magma Sea', 'Real Estate', 'Acquisition', 'Economy'],
      image: 'https://picsum.photos/seed/mhh009/580/320',
      imageCaption: 'The Magma Sea Sector at Z-Level 114, where Armok Holdings acquired three industrial parcels.',
      imageCredit: 'Bureau of Deep Works / Survey Division',
      body: [
        'MOUNTAINHOME \u2014 Armok Holdings LLC announced on Monday the acquisition of three commercial-industrial parcels in the Magma Sea Sector at Z-Level 114, completing a portfolio expansion the company first signalled at last autumn\'s Grand Duchy Infrastructure Investment Summit.',
        'The three parcels \u2014 designated MS-114-A, MS-114-B, and MS-114-C in the <a href="/l1/taxes/">Registry of Deeds</a> \u2014 were acquired from prior holders Fungiwood Trust, the Steelthunder Clan, and a private individual whose identity was not disclosed, for a combined consideration the company declined to specify. Registry filings reviewed by the Herald indicate total recorded transfer values of approximately 48,000 Gold Sovereigns.',
        '<div class="infoBox"><div class="infoTitle">TRANSACTION SUMMARY</div><div class="infoContent"><strong>Parcel MS-114-A:</strong> Acquired from Fungiwood Trust<br/><strong>Parcel MS-114-B:</strong> Acquired from Steelthunder Clan<br/><strong>Parcel MS-114-C:</strong> Acquired from undisclosed private seller<br/><strong>Combined value:</strong> ~48,000 Gold Sovereigns<br/><strong>Buyer:</strong> Armok Holdings LLC (Aban Flamehollow, managing partner)<br/><br/>Deed records: <a href="/l1/taxes/">ROD public counter</a>, Z-Level 1, Room 14</div></div>',
        '<div class="pullQuote">"The Magma Sea Sector remains the most strategically important industrial zone in the Grand Duchy."<span class="attribution">\u2014 Aban Flamehollow, Managing Partner, Armok Holdings LLC</span></div>',
        'Armok Holdings, which already operates two magma smelting facilities at Z-Level 110, is expected to use the new parcels to expand its refined-metal production capacity. The sale by the Steelthunder Clan is noteworthy given the Clan\'s <a href="javascript:navigateToArticle(\'MHH-019\')">recent legal dispute</a> with Koganusan Estates LLC over overlapping mineral claims. The company has not filed formal development plans with the Bureau of Deep Works as of press time.'
      ]
    },
    'MHH-010': {
      id: 'MHH-010', category: 'Culture', published: '2026-02-21T10:00:00',
      headline: "Grand Duchy Museum Unveils 'Forgotten Beast Collection'",
      author: 'Fikod Silentstone', byline: 'Arts & Culture Reporter',
      tags: ['Grand Duchy Museum', 'Forgotten Beasts', 'Exhibition', 'Culture', 'History'],
      image: 'https://picsum.photos/seed/mhh010/580/320',
      imageCaption: 'The near-complete skeleton of Ozan Moltenwing, centrepiece of the new Forgotten Beast Collection on Z-Level 4.',
      imageCredit: 'Grand Duchy Museum / Exhibition Department',
      body: [
        'MOUNTAINHOME \u2014 The Grand Duchy Museum of Natural and Arcane History opened its newest permanent exhibition, "Confronting the Deep: The Forgotten Beast Collection," to the public on Friday, drawing an opening-day attendance of over 800 dwarves.',
        'The exhibition, housed in three newly renovated galleries on Z-Level 4, presents skeletal remains, preserved specimens, and arcane artefacts associated with 31 Forgotten Beast encounters recorded in Grand Duchy annals since Year 42. It represents the museum\'s most comprehensive effort yet to document the Forgotten Beast phenomenon for general audiences.',
        '<div class="pullQuote">"These creatures are part of our history, however terrifying. Each one tells us something about the depths we have chosen to inhabit."<span class="attribution">\u2014 Museum Director Kogan Stonelens</span></div>',
        'Highlights of the collection include the near-complete skeleton of Ozan Moltenwing, the three-headed fire drake encountered at Z-Level 122 in Year 198, and the preserved shell segments of Tholtig Crystalline, the cave spider of extraordinary size that besieged Z-Level 67 for eleven months in Year 266. The <a href="javascript:navigateToArticle(\'MHH-004\')">Bard\'s Troupe production of "The Ballad of Boatmurdered"</a> drew on several of the same archival sources.',
        'Interactive rune-displays allow visitors to consult archival records of each beast encounter, cross-referenced with <a href="/l1/taxes/">Registry of Deeds</a> filings documenting property claims filed after the beasts were slain. Admission is 2 GP adults, 1 GP children under 50 years. The museum is open daily except during siege conditions.'
      ]
    },
    'MHH-011': {
      id: 'MHH-011', category: 'Weather', published: '2026-02-25T15:20:00', updated: '2026-03-01T16:00:00',
      headline: 'Surface Trade Route Closure Extended Through Mid-March',
      author: 'Zulban Tunnelworks', byline: 'Science Correspondent',
      tags: ['Trade Route', 'Surface Closure', 'Weather', 'Supply Chain'],
      image: 'https://picsum.photos/seed/mhh011/580/320',
      imageCaption: 'Snow accumulation on the primary surface trade route near the Outer Surface Zone.',
      imageCredit: 'Bureau of Surface Commerce',
      body: [
        'MOUNTAINHOME \u2014 The Bureau of Surface Commerce announced Wednesday that the primary surface trade route connecting Mountainhome to the Elven Forest Trading Post will remain closed through at least mid-March, extending a closure that had initially been projected to last only through the end of February.',
        'The route has been impassable since a combination of late-season blizzard conditions and goblin raiding activity in the Outer Surface Zone forced its suspension on the 14th of last month.',
        '<div class="pullQuote">"We understand this creates hardship. We are working with the Grand Duke\'s office to identify alternative supply channels through the mountain pass routes and via deep tunnel trading connections."<span class="attribution">\u2014 Bureau Director Iden Copperstone</span></div>',
        'The extended closure has already affected supplies of surface-origin goods in Mountainhome markets, with prices for above-ground timber, surface grain, and elf-manufactured cloth rising noticeably over the past two weeks. The disruption compounds existing economic pressures from the <a href="javascript:navigateToArticle(\'MHH-014\')">plump helmet harvest shortfall</a>.',
        '<div class="infoBox"><div class="infoTitle">SURFACE ROUTE STATUS</div><div class="infoContent"><strong>Route:</strong> Mountainhome \u2194 Elven Forest Trading Post<br/><strong>Status:</strong> CLOSED (since Feb 14)<br/><strong>Est. reopening:</strong> Mid-March (weather dependent)<br/><strong>Cause:</strong> Blizzard conditions + goblin raiding<br/><strong>Affected goods:</strong> Timber, surface grain, elf cloth<br/><br/>Inquiries: Bureau of Surface Commerce, Z-Level 1, Room 22</div></div>'
      ]
    },
    'MHH-012': {
      id: 'MHH-012', category: 'Politics', published: '2026-03-02T11:10:00',
      headline: 'Arcane Council Debates Mandatory Literacy Rune Testing',
      author: 'Urist McReporter', byline: 'Senior Correspondent, Politics Desk',
      tags: ['Arcane Council', 'Literacy', 'Rune Testing', 'Education Policy'],
      image: 'https://picsum.photos/seed/mhh012/580/320',
      imageCaption: 'Councillor Stonesinger and Councillor Deepvein exchange remarks during Monday\'s debate.',
      imageCredit: 'Herald Staff / Politics Desk',
      body: [
        'MOUNTAINHOME \u2014 A proposal to require mandatory literacy rune testing for all citizens seeking employment in civic positions drew sharp debate in the Arcane Council chamber on Monday, with supporters calling it essential to administrative competency and opponents characterising it as an unfair barrier to working-class dwarves.',
        'The proposal, introduced by Councillor Urist Stonesinger (Guild Ward), would require applicants for any civic position \u2014 including forge workers employed by Bureau-operated facilities, not just administrative staff \u2014 to pass a standardised literacy rune examination developed by the Bureau of Education.',
        '<div class="pullQuote">"Every dwarf working in a Bureau facility must be able to read safety instructions and emergency protocols. This is not elitism. This is basic operational necessity."<span class="attribution">\u2014 Councillor Urist Stonesinger (Guild Ward)</span></div>',
        'Opposition was led by Councillor Bomrek Deepvein (Residential Quarter), who argued that the examination standards were designed by and for guild-educated dwarves, systematically disadvantaging those trained through apprenticeships rather than formal schooling.',
        '<div class="pullQuote">"You are proposing to deny honest dwarves honest work because they learned their craft from a master rather than a rune-scribe."<span class="attribution">\u2014 Councillor Bomrek Deepvein (Residential Quarter)</span></div>',
        'The Council referred the proposal to committee for further review, with a deadline of late spring for a revised version. The debate follows other contentious council activity including the <a href="javascript:navigateToArticle(\'MHH-001\')">magma infrastructure expansion vote</a> and the <a href="javascript:navigateToArticle(\'MHH-006\')">expulsion of the goblin diplomatic envoy</a>.'
      ]
    },
    'MHH-013': {
      id: 'MHH-013', category: 'Crime', published: '2026-03-06T17:35:00',
      headline: 'Rune-Wire Fraud Ring Dismantled; 12 Arrested',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Crime Desk',
      tags: ['Rune-Wire Fraud', 'Arrest', 'Fortress Guard', 'Financial Crime'],
      image: 'https://picsum.photos/seed/mhh013/580/320',
      imageCaption: 'Fortress Guard officers at the Z-Level 6 Guard Station following the arrest of 12 suspects in Operation Hollow Stone.',
      imageCredit: 'Fortress Guard / Public Affairs',
      body: [
        'MOUNTAINHOME \u2014 Fortress Guard investigators announced Thursday that a coordinated operation has dismantled a rune-wire fraud network responsible for an estimated 6,200 Gold Sovereigns in losses across the Grand Duchy, resulting in 12 arrests across four z-levels.',
        'The investigation, designated Operation Hollow Stone, spanned eight months and involved collaboration between the Fortress Guard Financial Crimes Unit, the Bureau of Rune-Wire Communications, and the Mountainhome Merchant\'s Guild security office.',
        'According to Guard Captain Aban Axewright, the network operated by intercepting legitimate rune-wire payment transmissions between merchants and substituting fraudulent routing instructions that redirected funds to controlled receiving accounts. At least 47 merchants are identified as victims, the Guard said.',
        '<div class="infoBox"><div class="infoTitle">OPERATION HOLLOW STONE \u2014 BY THE NUMBERS</div><div class="infoContent"><strong>Duration:</strong> 8-month investigation<br/><strong>Arrests:</strong> 12 (across 4 z-levels)<br/><strong>Estimated losses:</strong> 6,200 Gold Sovereigns<br/><strong>Victims:</strong> 47+ merchants<br/><strong>Charges:</strong> Organised fraud, Grand Duchy Commerce Code<br/><strong>Agencies:</strong> Fortress Guard FCU, Bureau of Rune-Wire Comms, Merchant\'s Guild Security</div></div>',
        '<div class="pullQuote">"Rune-wire payment security is the backbone of our commercial system. Financial fraud at this scale will be pursued with the full resources of the Guard."<span class="attribution">\u2014 Guard Captain Aban Axewright</span></div>',
        'Those arrested range in age from 28 to 64 and include two former Bureau of Rune-Wire technicians, a guild-licensed communications broker, and nine alleged intermediaries. Bond hearings are scheduled for early next week. Related commercial filings can be reviewed at the <a href="/l1/taxes/">Registry of Deeds</a>.'
      ]
    },
    'MHH-014': {
      id: 'MHH-014', category: 'Economy', published: '2026-03-09T12:48:00',
      headline: 'Plump Helmet Harvest Forecast Slashed 18% After Cave Mold Infestation',
      author: 'Rigoth Gemcutter', byline: 'Economics Correspondent',
      tags: ['Plump Helmets', 'Agriculture', 'Cave Mold', 'Food Supply', 'Economy'],
      image: 'https://picsum.photos/seed/mhh014/580/320',
      imageCaption: 'Deeprock Gray Mold visible on plump helmet crops in Growing Sector 9 on Z-Level 25.',
      imageCredit: 'Bureau of Subterranean Agriculture',
      body: [
        'MOUNTAINHOME \u2014 The Bureau of Subterranean Agriculture released a revised growing season forecast on Sunday, projecting plump helmet mushroom output at 82 per cent of its earlier estimate after a cave mold infestation was confirmed in Growing Sectors 7 through 11 on Z-Level 25.',
        'The infestation, caused by an aggressive strain of Deeprock Gray Mold, was first identified by sector foremen approximately three weeks ago. Containment efforts have been ongoing, but Bureau agronomists now believe the spread has affected too large an area to fully arrest before the end of the current growing cycle.',
        '<div class="pullQuote">"We are not looking at a food crisis. We have strategic reserves sufficient for 14 months at standard consumption. But plump helmet prices will rise and rationing of fresh helmets for non-essential uses is under consideration."<span class="attribution">\u2014 Bureau Director Morul Farmstone</span></div>',
        'Plump helmets are the Grand Duchy\'s primary cultivated food source and a feedstock for Dwarven ale production. The shortfall compounds supply pressures from the ongoing <a href="javascript:navigateToArticle(\'MHH-011\')">surface trade route closure</a>.',
        '<div class="infoBox"><div class="infoTitle">HARVEST IMPACT</div><div class="infoContent"><strong>Forecast reduction:</strong> 18% below original estimate<br/><strong>Affected sectors:</strong> Growing Sectors 7\u201311, Z-Level 25<br/><strong>Cause:</strong> Deeprock Gray Mold infestation<br/><strong>Strategic reserves:</strong> 14 months at standard consumption<br/><strong>Ale impact:</strong> Reformulation underway, no major curtailment expected<br/><br/>Report unusual mold: Bureau of Subterranean Agriculture, Z-Level 3, Room 17</div></div>'
      ]
    },
    'MHH-015': {
      id: 'MHH-015', category: 'Sports', published: '2026-03-11T20:15:00',
      headline: 'Fortress Wrestling League Opens Season; Avar Ironhand Defends Championship',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Sports Desk',
      tags: ['Wrestling', 'Fortress Wrestling League', 'Avar Ironhand', 'Season Opener'],
      image: 'https://picsum.photos/seed/mhh015/580/320',
      imageCaption: 'Avar Ironhand raises his fist after retaining the Heavyweight Championship at the Grand Arena.',
      imageCredit: 'Bomrek Hammerfall / Herald Sports',
      body: [
        'MOUNTAINHOME \u2014 The Fortress Wrestling League opened its Year 312 season at the Grand Arena on Z-Level 8 on Wednesday evening with a sold-out card of eight bouts, headlined by defending Heavyweight Champion Avar Ironhand\'s successful title defence against challenger Urist Stoneback.',
        'Ironhand, who captured his first League championship in Year 309 and has since defended it four times, submitted Stoneback in the second round of a scheduled five-round main event to retain the title. The capacity crowd of 680 gave Ironhand a prolonged standing ovation. Ironhand previously dominated the <a href="javascript:navigateToArticle(\'MHH-007\')">Z-Level Games</a> held in early February.',
        '<div class="pullQuote">"Season opener. Season is long. More to come."<span class="attribution">\u2014 Avar Ironhand, Heavyweight Champion</span></div>',
        'The undercard featured three newcomers making their League debuts. Of particular note was Dumed Rockhammer, 21, who secured a decisive first-round victory over veteran Meng Axearm in what observers called the most impressive debut performance in three seasons.',
        '<div class="infoBox"><div class="infoTitle">SEASON OPENER \u2014 RESULTS</div><div class="infoContent"><strong>Main Event:</strong> Avar Ironhand def. Urist Stoneback (submission, Rd. 2) \u2014 Heavyweight Title<br/><strong>Co-Main:</strong> Iden Hammerleg def. Aban Rockfist (decision) \u2014 Light Heavyweight<br/><strong>Featured:</strong> Dumed Rockhammer def. Meng Axearm (TKO, Rd. 1) \u2014 Middleweight debut<br/><strong>Attendance:</strong> 680 (sold out)<br/><strong>Next event:</strong> March 25<br/><br/>Tickets & live scores: <a href="/l1/scoretap/">ScoreTap</a></div></div>'
      ]
    },
    'MHH-016': {
      id: 'MHH-016', category: 'Politics', published: '2026-03-11T10:30:00', updated: '2026-03-11T16:45:00',
      headline: 'Surface Relations Act Passes Second Reading',
      author: 'Urist McReporter', byline: 'Senior Correspondent, Politics Desk',
      tags: ['Surface Relations Act', 'Arcane Council', 'Legislation', 'Foreign Policy'],
      image: 'https://picsum.photos/seed/mhh016/580/320',
      imageCaption: 'The Arcane Council chamber during Wednesday\'s 6-3 vote on the Surface Relations Normalisation Act.',
      imageCredit: 'Urist McReporter / Herald Politics',
      body: [
        'MOUNTAINHOME \u2014 The Arcane Council passed the Surface Relations Normalisation Act on second reading Wednesday morning by a vote of 6-3, advancing the most comprehensive framework for regulating Mountainhome\'s dealings with surface nations in nearly four decades.',
        'The Act, if it passes the required third reading, would establish a permanent Bureau of Surface Affairs, create a formal ambassador designation for Grand Duchy representatives to surface polities, and set binding protocols for the inspection of surface trade goods entering via the Upper Gate. The legislation has taken on added urgency following the <a href="javascript:navigateToArticle(\'MHH-006\')">expulsion of the goblin diplomatic envoy</a> last month.',
        '<div class="pullQuote">"We trade with elves, with humans, occasionally with other dwarven outposts. We need a system, not a collection of old proclamations."<span class="attribution">\u2014 Councillor Urist Stonesinger</span></div>',
        'The three dissenting councillors \u2014 Deepvein, Moldath, and Avar \u2014 objected primarily to provisions granting surface ambassadors access to the Mountainhome Trade Registry, which they characterised as a security risk. Trade registry data is also accessible through the <a href="/l1/taxes/">Registry of Deeds</a> public portal.',
        '<div class="infoBox"><div class="infoTitle">SURFACE RELATIONS ACT \u2014 KEY PROVISIONS</div><div class="infoContent"><strong>Bureau of Surface Affairs:</strong> Permanent agency for surface diplomacy<br/><strong>Ambassador designation:</strong> Formal envoy roles for surface polities<br/><strong>Trade inspection:</strong> Binding protocols at Upper Gate<br/><strong>Registry access:</strong> Surface ambassadors granted Trade Registry access (contested)<br/><strong>Vote:</strong> 6-3 on second reading<br/><strong>Third reading:</strong> Within 30 days<br/><strong>Effective date:</strong> Start of Year 313 (if passed)</div></div>'
      ]
    },
    'MHH-017': {
      id: 'MHH-017', category: 'Culture', published: '2026-03-11T14:00:00',
      headline: "Goden Boulderback's Platinum Statue Wins Grand Duke's Medal",
      author: 'Fikod Silentstone', byline: 'Arts & Culture Reporter',
      tags: ['Goden Boulderback', 'Grand Duke Medal', 'Sculpture', 'Platinum', 'Arts Award'],
      image: 'https://picsum.photos/seed/mhh017/580/320',
      imageCaption: 'Goden Boulderback receives the Grand Duke\'s Medal from Grand Duke Aban the Steadfast.',
      imageCredit: 'Fikod Silentstone / Herald Arts',
      body: [
        'MOUNTAINHOME \u2014 Master sculptor Goden Boulderback received the Grand Duke\'s Medal for Artistic Excellence on Wednesday at the annual Grand Duchy Arts Recognition Ceremony, awarded for his monumental platinum statue "The Overseer\'s Burden," which has been on permanent display in the Grand Hall since its completion last autumn.',
        'The statue, cast from a single 840-kilogram block of refined platinum sourced from <a href="javascript:navigateToArticle(\'MHH-009\')">Armok Holdings\' Z-Level 110 processing facility</a>, depicts a stylised dwarven overseer in the act of consulting a construction blueprint while a fortress rises behind them. Standing 4.2 meters tall, it is the largest platinum casting completed in the Grand Duchy in over a century.',
        '<div class="pullQuote">"This is the work of twenty-three years. I have thought about this statue since I was an apprentice. To see it finished and to receive this recognition in the same year \u2014 I lack the runes for it."<span class="attribution">\u2014 Goden Boulderback, Master Sculptor</span></div>',
        '<div class="infoBox"><div class="infoTitle">GRAND DUKE\'S MEDAL \u2014 PAST RECIPIENTS</div><div class="infoContent"><strong>Year 312:</strong> Goden Boulderback (sculpture)<br/><strong>Year 308:</strong> Zulban Inkstone\u2020 (lithography)<br/><strong>Year 305:</strong> Kogan Wallcarver (murals)<br/><strong>Year 298:</strong> Iden Drumstone (composition)<br/><br/>Presented annually by the Grand Duke for exceptional contribution to the arts of the Duchy.</div></div>',
        '"The Overseer\'s Burden" is open to public viewing in the Grand Hall, Z-Level 1, during standard civic hours. A commemorative catalogue of Boulderback\'s complete works is available at the <a href="javascript:navigateToArticle(\'MHH-010\')">Grand Duchy Museum</a> gift counter.'
      ]
    },
    'MHH-018': {
      id: 'MHH-018', category: 'Crime', published: '2026-03-11T01:45:00', updated: '2026-03-11T14:30:00',
      headline: 'Z-Level 28 Tavern Brawl Leaves Five Hospitalized',
      author: 'Bomrek Hammerfall', byline: 'Staff Reporter, Crime Desk',
      tags: ['Tavern Brawl', 'Z-Level 28', 'Hospitalized', 'Fortress Guard'],
      image: 'https://picsum.photos/seed/mhh018/580/320',
      imageCaption: 'The Cracked Anvil tavern on Z-Level 28 remained closed Thursday following the incident.',
      imageCredit: 'Bomrek Hammerfall / Herald Crime',
      body: [
        'MOUNTAINHOME \u2014 A late-night brawl at the Cracked Anvil tavern on Z-Level 28 left five dwarves requiring treatment at the Fortress Infirmary on Wednesday, with two described as having serious injuries, following an altercation that Fortress Guard officers say involved at least 15 participants.',
        'Guards responded to the Cracked Anvil shortly after midnight following a rune-wire alert from the tavern\'s proprietor, Dumed Alecarver. Officers found the tavern\'s main common room in significant disarray, with five injured dwarves, extensive damage to furniture and ceramic ware, and approximately twelve individuals who had departed the premises before guards arrived.',
        '<div class="pullQuote">"We have a reasonable picture of how the incident started. We are identifying the remaining participants."<span class="attribution">\u2014 Guard Sergeant Rimtar Hammerpost</span></div>',
        'The two most seriously injured were admitted to the Infirmary overnight, one with a fractured orbital bone and one with a dislocated shoulder complicated by a pre-existing joint condition. The remaining three were treated and released. No fatalities were reported.',
        'Alecarver, the proprietor, said in a brief statement: "The Cracked Anvil has operated on this level for 40 years without an incident of this kind. We are cooperating fully with the Guard." The Cracked Anvil remained closed on Thursday pending a Guard inspection of the premises. The tavern\'s commercial licence is on file at the <a href="/l1/taxes/">Registry of Deeds</a>.'
      ]
    },
    'MHH-019': {
      id: 'MHH-019', category: 'Economy', published: '2026-03-11T09:15:00',
      headline: 'Steelthunder Clan Files Injunction Against Koganusan Estates LLC',
      author: 'Rigoth Gemcutter', byline: 'Economics Correspondent',
      tags: ['Steelthunder Clan', 'Koganusan Estates', 'Injunction', 'Property Dispute', 'Legal'],
      image: 'https://picsum.photos/seed/mhh019/580/320',
      imageCaption: 'The disputed excavation site in the Z-Level 35 Eastern Cavern Network.',
      imageCredit: 'Herald Staff',
      body: [
        'MOUNTAINHOME \u2014 The Steelthunder Clan filed for an emergency injunction in Grand Duchy Circuit Court on Tuesday seeking to halt Koganusan Estates LLC from proceeding with excavation work on a parcel in the Z-Level 35 Eastern Cavern Network that the Clan alleges encroaches on a pre-existing ancestral mineral claim recorded in Year 189.',
        'The injunction application, reviewed by the Herald, argues that Koganusan Estates\' recently approved excavation permit encompasses a 40-meter corridor that overlaps with Claim ST-189-EAST, which the Steelthunder Clan says has been continuously maintained in the <a href="/l1/taxes/">Registry of Deeds</a> for 137 years.',
        '<div class="pullQuote">"This is not a boundary dispute. Our claim is unambiguous in the records. Koganusan knew or should have known before they applied for that permit."<span class="attribution">\u2014 Morul Stonecleave, Steelthunder Clan Counsel</span></div>',
        'Koganusan Estates LLC disputed the characterisation, contending that the ancestral claim expired under Year 302 ordinance amendments governing dormant mineral claims. The Steelthunder Clan recently <a href="javascript:navigateToArticle(\'MHH-009\')">sold a Magma Sea Sector parcel to Armok Holdings LLC</a>, suggesting the clan is actively managing its property portfolio.',
        '<div class="infoBox"><div class="infoTitle">CASE SUMMARY</div><div class="infoContent"><strong>Plaintiff:</strong> Steelthunder Clan<br/><strong>Defendant:</strong> Koganusan Estates LLC<br/><strong>Claim:</strong> ST-189-EAST (ancestral mineral rights, Year 189)<br/><strong>Dispute:</strong> 40m corridor overlap in Z-Level 35 Eastern Cavern<br/><strong>Hearing:</strong> Friday morning, Grand Duchy Courthouse, Z-Level 2, Room 14<br/><strong>Judge:</strong> Circuit Judge Urist Hammerwright<br/><br/>Deed records: <a href="/l1/taxes/">Registry of Deeds portal</a></div></div>'
      ]
    },
    'MHH-020': {
      id: 'MHH-020', category: 'Weather', published: '2026-03-11T11:00:00',
      headline: "Geomancer's Annual Report: Year 312 Trending 'Exceptionally Stable'",
      author: 'Zulban Tunnelworks', byline: 'Science Correspondent',
      tags: ['Geomancer', 'Annual Report', 'Stability', 'Year 312', 'Forecast'],
      image: 'https://picsum.photos/seed/mhh020/580/320',
      imageCaption: 'Chief Geomancer Zulban Deepstone presents the Year 312 annual stability report.',
      imageCredit: 'Zulban Tunnelworks / Herald Science',
      body: [
        'MOUNTAINHOME \u2014 The Geomancer\'s Office released its annual subterranean conditions report for the first quarter of Year 312 on Wednesday, characterising the overall geomantic environment as "Exceptionally Stable" \u2014 the highest stability rating the Office has assigned in any first-quarter report in 14 years.',
        'The report, which synthesises data from 86 monitoring stations distributed across Z-Levels 1 through 140, found tectonic stress indices at their lowest quarterly average since Year 298, magma sea surface pressure within the lowest 10 per cent of all historical readings, and aquifer flow rates stable across all monitored deep-water systems.',
        '<div class="pullQuote">"By every primary metric, the fortress\'s geological foundation is performing exceptionally well. This does not mean complacency is warranted \u2014 the Granite Flats advisory remains in effect \u2014 but the overall picture is genuinely encouraging."<span class="attribution">\u2014 Chief Geomancer Zulban Deepstone</span></div>',
        'The report does note two areas of continued monitoring: the <a href="javascript:navigateToArticle(\'MHH-005\')">previously disclosed seismic advisory zone around Z-Level 45</a>, which remains at Elevated Concern status, and a developing pressure differential in the Z-Level 90\u2013100 corridor that the Geomancer\'s Office is classifying as a Watchlist Item pending further data collection over the next quarter.',
        '<div class="infoBox"><div class="infoTitle">YEAR 312 Q1 \u2014 GEOMANTIC SUMMARY</div><div class="infoContent"><strong>Overall rating:</strong> Exceptionally Stable (highest in 14 years)<br/><strong>Monitoring stations:</strong> 86 (Z-Levels 1\u2013140)<br/><strong>Tectonic stress:</strong> Lowest quarterly average since Year 298<br/><strong>Magma sea pressure:</strong> Bottom 10% of all historical readings<br/><strong>Aquifer flow:</strong> Stable across all systems<br/><strong>Watchlist:</strong> Z-Level 45 (Elevated), Z-Level 90\u2013100 (monitoring)<br/><br/>Full report: Geomancer\'s Office, Z-Level 1, Room 8 (0.50 GP)</div></div>'
      ]
    }
  };

  var categoryBadgeClass = {
    'Politics': 'statusReview', 'Crime': 'statusPending', 'Economy': 'statusApproved',
    'Culture': 'statusReview', 'Sports': 'statusApproved', 'Weather': 'statusPending'
  };

  // Decode sentinel URL
  var urlParams = new URLSearchParams(window.location.search);
  var rawPostData = urlParams.has('postData') ? decodeURIComponent(urlParams.get('postData')) : '';
  var articleId = '';
  if (rawPostData.indexOf('XXXNNNXXX') !== -1) {
    var parts = rawPostData.split('XXXNNNXXX');
    for (var i = 0; i < parts.length; i++) {
      if (parts[i].indexOf('ID=') !== -1) {
        articleId = decodeURIComponent(parts[i].split('ID=')[1].split('&')[0]);
        break;
      }
    }
  }

  var article = articleId ? ARTICLES[articleId] : null;

  if (article) {
    document.title = article.headline + ' - Mountainhome Herald';
    document.getElementById('articleTitle').textContent = article.headline;

    // Update breadcrumb
    var bcSpans = document.querySelectorAll('.breadcrumbs span:last-child');
    if (bcSpans.length) bcSpans[bcSpans.length - 1].textContent = article.headline;

    document.getElementById('lblId').textContent = article.id;

    // Format published datetime
    var pubDate = new Date(article.published);
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var h = pubDate.getHours(), m = pubDate.getMinutes().toString().padStart(2,'0');
    var ampm = h >= 12 ? 'PM' : 'AM'; var h12 = h % 12 || 12;
    document.getElementById('lblDate').textContent =
      months[pubDate.getMonth()] + ' ' + pubDate.getDate() + ', ' + pubDate.getFullYear() +
      ' at ' + h12 + ':' + m + ' ' + ampm;

    if (article.updated) {
      var upd = new Date(article.updated);
      var uh = upd.getHours(), um = upd.getMinutes().toString().padStart(2,'0');
      var uampm = uh >= 12 ? 'PM' : 'AM'; var uh12 = uh % 12 || 12;
      document.getElementById('rowUpdated').style.display = '';
      document.getElementById('lblUpdated').innerHTML =
        months[upd.getMonth()] + ' ' + upd.getDate() + ', ' + upd.getFullYear() +
        ' at ' + uh12 + ':' + um + ' ' + uampm +
        ' <span style="color:#cc0000;font-size:10px;font-weight:bold;">UPDATED</span>';
    }

    document.getElementById('lblAuthor').textContent = article.author;
    document.getElementById('lblByline').textContent = article.byline;

    var catEl = document.getElementById('lblCategory');
    catEl.textContent = article.category;
    catEl.className = categoryBadgeClass[article.category] || 'statusApproved';

    document.getElementById('lblTags').innerHTML = article.tags.map(function(t) {
      return '<span>' + t + '</span>';
    }).join(' ');

    // Image
    if (article.image) {
      var imgSection = document.getElementById('articleImage');
      document.getElementById('articleImg').src = article.image;
      document.getElementById('articleImg').alt = article.headline;
      document.getElementById('imgCaption').textContent = article.imageCaption || '';
      document.getElementById('imgCredit').textContent = article.imageCredit || '';
      imgSection.style.display = '';
    }

    // Body
    document.getElementById('articleBody').innerHTML = article.body.map(function(p) {
      if (p.indexOf('<div') === 0) return p;
      return '<p>' + p + '</p>';
    }).join('');

    // Related articles
    var related = [];
    var ids = Object.keys(ARTICLES);
    for (var j = 0; j < ids.length && related.length < 3; j++) {
      if (ids[j] !== articleId && ARTICLES[ids[j]].category === article.category) {
        related.push(ARTICLES[ids[j]]);
      }
    }
    var relEl = document.getElementById('relatedLinks');
    if (related.length > 0) {
      relEl.innerHTML = related.map(function(r) {
        return '<a href="javascript:navigateToArticle(\'' + r.id + '\')">' + r.headline + '</a>';
      }).join('');
    } else {
      document.getElementById('relatedSection').style.display = 'none';
    }

    // ── Comments ──
    var COMMENTS = {
      'MHH-001': [
        { name: 'Dumed Copperbeard', guild: 'Stonemasons\' Ward', time: '2026-01-01T12:30:00', text: 'About time the Council invested in eastern infrastructure. Those of us in the Granite Flats have been petitioning for magma access since Year 305.', replies: [
          { name: 'Fikod Ironbrow', guild: '', time: '2026-01-01T14:15:00', text: 'Easy to say when you aren\'t footing the 14,000 GP bill. Where is the funding analysis?' }
        ]},
        { name: 'Ingiz Quartzgaze', guild: 'Bureau of Deep Works', time: '2026-01-02T08:00:00', text: 'The Bureau welcomes the Council\'s decision. We have already begun preliminary survey work in the target corridor.', replies: [] },
        { name: 'Thob Tunnelvein', guild: '', time: '2026-01-02T14:22:00', text: 'My workshop is on Z-Level 38 and we\'ve needed better magma routing for years. The current east-side pipe is corroded and only runs half capacity.', replies: [] },
      ],
      'MHH-002': [
