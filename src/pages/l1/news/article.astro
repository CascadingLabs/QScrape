    var comments = COMMENTS[articleId] || [];
    var commentsEl = document.getElementById('commentsList');
    if (comments.length > 0) {
      commentsEl.innerHTML = comments.map(function(c) {
        var guildStr = c.guild ? ' <span style="color:#666; font-size:9px;">(' + c.guild + ')</span>' : '';
        var cDate = new Date(c.time);
        var dateStr = (cDate.getMonth()+1) + '/' + cDate.getDate() + '/' + cDate.getFullYear() + ' ' + (cDate.getHours() % 12 || 12) + ':' + String(cDate.getMinutes()).padStart(2,'0') + (cDate.getHours() >= 12 ? ' PM' : ' AM');
        var html = '<div class="commentItem">' +
          '<div class="commentHeader"><strong>' + c.name + '</strong>' + guildStr + ' <span class="commentDate">' + dateStr + '</span></div>' +
          '<div class="commentBody">' + c.text + '</div>';
        if (c.replies && c.replies.length > 0) {
          html += c.replies.map(function(r) {
            var rGuild = r.guild ? ' <span style="color:#666; font-size:9px;">(' + r.guild + ')</span>' : '';
            var rDate = new Date(r.time);
            var rDateStr = (rDate.getMonth()+1) + '/' + rDate.getDate() + '/' + rDate.getFullYear() + ' ' + (rDate.getHours() % 12 || 12) + ':' + String(rDate.getMinutes()).padStart(2,'0') + (rDate.getHours() >= 12 ? ' PM' : ' AM');
            return '<div class="commentReply">' +
              '<div class="commentHeader"><strong>' + r.name + '</strong>' + rGuild + ' <span class="commentDate">' + rDateStr + '</span></div>' +
              '<div class="commentBody">' + r.text + '</div>' +
            '</div>';
          }).join('');
        }
        html += '</div>';
        return html;
      }).join('');
    } else {
      commentsEl.innerHTML = '<p style="font-size:11px; color:#999; font-style:italic;">No comments have been posted for this article.</p>';
    }

    // ── JSON-LD Structured Data ──
    var jsonLd = {
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "headline": article.headline,
      "description": article.excerpt || '',
      "image": article.image,
      "datePublished": article.published,
      "dateModified": article.updated || article.published,
      "author": {
        "@type": "Person",
        "name": article.author,
        "jobTitle": article.byline
      },
      "publisher": {
        "@type": "Organization",
        "name": "Mountainhome Herald",
        "url": "http://localhost:4321/l1/news/"
      },
      "mainEntityOfPage": window.location.href,
      "articleSection": article.category,
      "keywords": article.tags ? article.tags.join(', ') : '',
      "commentCount": comments.length,
      "comment": comments.map(function(c) {
        return {
          "@type": "Comment",
          "author": { "@type": "Person", "name": c.name },
          "dateCreated": c.time,
          "text": c.text
        };
      })
    };
    document.getElementById('jsonLd').textContent = JSON.stringify(jsonLd);

  } else {
    document.getElementById('articleTitle').textContent = 'Article Not Found';
    document.getElementById('articleBody').innerHTML = '<p>The requested article could not be found. Please <a href="/l1/news/articles">return to the article listing</a>.</p>';
    document.getElementById('relatedSection').style.display = 'none';
  }
