                <div class="sidebarBox">
                    <h4>BY CATEGORY</h4>
                    <div class="sidebarContent">
                        <div class="catCount">
                            <span><a href="javascript:filterCategory('Politics')">Politics</a></span>
                            <span>4</span>
                        </div>
                        <div class="catCount">
                            <span><a href="javascript:filterCategory('Crime')">Crime</a></span>
                            <span>4</span>
                        </div>
                        <div class="catCount">
                            <span><a href="javascript:filterCategory('Economy')">Economy</a></span>
