---
import HeraldShell from './_components/HeraldShell.astro';
import AdUnit from './_components/AdUnit.astro';
import { getLatest, getByCategory, getBreaking, categories, formatDateTime, formatTime } from './_data/articles';

const latest = getLatest(20);
const featured = latest[0]; // Most recent by published time
const topStories = latest.slice(1, 5);
const newsFeed = latest.slice(5, 13);
const breaking = getBreaking();
const categoryCounts = Object.fromEntries(categories.map(c => [c, getByCategory(c).length]));
---

<HeraldShell title="Home" activePage="home" breadcrumbs={[{ label: 'Home' }]}>

  <div class="categoryStrip" id="categoryStrip">
    <a href="javascript:void(0)" onclick="filterCategory('')" class="active" id="cat-All">All</a>
    {categories.map(c => (
      <a href="javascript:void(0)" onclick={`filterCategory('${c}')`} id={`cat-${c}`}>{c}</a>
    ))}
  </div>

  <div class="pageTitle">Rolling News Feed &mdash; Last updated {formatDateTime(featured.published)}</div>

  <div class="twoCol clearfix">
    <!-- Main column -->
    <div class="mainCol">
      <!-- Featured story -->
      <div class="featuredBox articleCard" data-category={featured.category}>
        <div class="featuredLabel">
          FEATURED
          {featured.updated && <span style="margin-left:8px;font-size:9px;color:#ffcc00;">UPDATED</span>}
        </div>
        <img class="featuredImg" src={featured.image.replace('/580/', '/560/').replace('/320', '/280')}
          alt={featured.headline} />
        <div class="featuredImgCaption">{featured.imageCaption} — {featured.imageCredit}</div>
        <div class="featuredContent">
          <h2>
            <a href="javascript:void(0)" onclick={`navigateToArticle('${featured.id}')`}>{featured.headline}</a>
          </h2>
          <div class="cardMeta">
            <span class={`categoryBadge cat-${featured.category}`}>{featured.category}</span>&nbsp;
            {formatDateTime(featured.published)} &mdash; {featured.author}
            &nbsp;<span class="cardTimeAgo" data-time-ago={featured.published}></span>
          </div>
          <p style="margin-top:6px;">{featured.excerpt}</p>
          <p>
            <a href="javascript:void(0)" onclick={`navigateToArticle('${featured.id}')`}>Read full story &raquo;</a>
          </p>
        </div>
      </div>

      <!-- Top stories -->
      <div class="topStoriesBox">
        <h3>Top Stories</h3>
        {topStories.map(a => (
          <div class="articleCard" data-category={a.category}>
            <img class="cardThumb" src={a.image.replace('/580/', '/80/').replace('/320', '/55')} alt={a.headline} />
            <div class="cardMeta">
              <span class={`categoryBadge cat-${a.category}`}>{a.category}</span>&nbsp;
              {formatDateTime(a.published)}
              &nbsp;<span class="cardTimeAgo" data-time-ago={a.published}></span>
              {a.updated && <span style="color:#cc0000;font-size:9px;margin-left:4px;">UPDATED</span>}
            </div>
            <a href="javascript:void(0)" onclick={`navigateToArticle('${a.id}')`} class="cardHeadline">{a.headline}</a>
            <div class="cardExcerpt">{a.excerpt}</div>
          </div>
        ))}
      </div>

      <!-- Inline ad -->
      <div class="adSlot--inline">
        <AdUnit size="banner" adId="DSN-BAN-001" text="Dwarven Iron Guild &mdash; Quality Forgework Since Year 89" cta="Find a Smith" placement="home_inline" />
      </div>

      <!-- Latest news feed -->
      <div class="latestBox">
        <h3>Latest News</h3>
        <ul>
          {newsFeed.map(a => (
            <li data-category={a.category}>
              <span class={`categoryBadge cat-${a.category}`}>{a.category}</span>&nbsp;
              <a href="javascript:void(0)" onclick={`navigateToArticle('${a.id}')`}>{a.headline}</a>
              <span class="cardMeta"> &mdash; {formatTime(a.published)}</span>
              <span class="cardTimeAgo" data-time-ago={a.published}></span>
              {a.updated && <span style="color:#cc0000;font-size:9px;margin-left:4px;">UPDATED</span>}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebarCol">
      <div class="sidebarBox">
        <h4>BREAKING</h4>
        <div class="sidebarContent">
          {breaking.map(a => (
            <div class="breakingItem">
              <strong><a href="javascript:void(0)" onclick={`navigateToArticle('${a.id}')`}>{a.headline}</a></strong>
              <div class="cardTimeAgo" data-time-ago={a.published}></div>
            </div>
          ))}
        </div>
      </div>

      <div class="adSlot--inline" style="margin:10px 15px 10px 5px;">
        <AdUnit size="rectangle" adId="DSN-REC-001" text="Armok Holdings LLC &mdash; Industrial Parcels Now Available at Z-Level 114" cta="View Listings" placement="home_sidebar_1" />
      </div>

      <div class="sidebarBox">
        <h4>BY CATEGORY</h4>
        <div class="sidebarContent">
          {categories.map(c => (
            <div class="catCount">
              <span><a href="javascript:void(0)" onclick={`filterCategory('${c}')`}>{c}</a></span>
              <span>{categoryCounts[c]}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="sidebarBox">
        <h4>PHOTO OF THE DAY</h4>
        <img class="sidebarImg" src="https://picsum.photos/seed/mhh-potd/190/140" alt="The Overseer's Burden statue in the Grand Hall" />
        <div class="sidebarContent">
          <strong><a href="javascript:void(0)" onclick="navigateToArticle('MHH-017')">"The Overseer's Burden"</a></strong><br/>
          Goden Boulderback's award-winning platinum statue in the Grand Hall, Z-Level 1.
          <a href="javascript:void(0)" onclick="navigateToArticle('MHH-017')">Story &raquo;</a>
        </div>
      </div>

      <div class="sidebarBox">
        <h4>ABOUT THE HERALD</h4>
        <div class="sidebarContent">
          Founded Year 89 by Urist McDwarfquill.
          The Grand Duchy's independent record of events since the Third Age of Mining.
          <br/><br/>
          <a href="/l1/news/staff">Editorial staff &raquo;</a><br/>
          <a href="/l1/news/contact">Contact us &raquo;</a>
        </div>
      </div>

      <div class="adSlot--inline" style="margin:10px 15px 10px 5px;">
        <AdUnit size="rectangle" adId="DSN-REC-002" text="Grand Arena &mdash; FWL Season Tickets On Sale Now" cta="Buy Tickets" placement="home_sidebar_2" />
      </div>

      <div class="sidebarBox">
        <h4>SCORETAP LIVE</h4>
        <div class="sidebarContent">
          Follow live scores from the Fortress Wrestling League and Z-Level Games.
          <br/><br/>
          <a href="/l1/scoretap/">Open ScoreTap &raquo;</a>
        </div>
      </div>

      <div class="sidebarBox">
        <h4>ROD RECORDS</h4>
        <div class="sidebarContent">
          Search property deeds, mortgages, and liens in the Arcane Registry of Deeds.
          <br/><br/>
          <a href="/l1/taxes/">Open ROD Records &raquo;</a>
        </div>
      </div>
    </div>
  </div>

  <div style="clear:both;"></div>

  <script is:inline>
  function filterCategory(cat) {
    var links = document.querySelectorAll('#categoryStrip a');
    for (var i = 0; i < links.length; i++) links[i].classList.remove('active');
    var activeId = cat ? 'cat-' + cat : 'cat-All';
    var el = document.getElementById(activeId);
    if (el) el.classList.add('active');

    document.querySelectorAll('.articleCard[data-category]').forEach(function(c) {
      c.style.display = (!cat || c.getAttribute('data-category') === cat) ? '' : 'none';
    });
    document.querySelectorAll('.latestBox li[data-category]').forEach(function(li) {
      li.style.display = (!cat || li.getAttribute('data-category') === cat) ? '' : 'none';
    });
  }
  </script>
</HeraldShell>
