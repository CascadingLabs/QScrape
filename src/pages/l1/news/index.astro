                            <span class="cardMeta"> &mdash; Feb 11</span>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="sidebarCol">
                <div class="sidebarBox">
                    <h4>BREAKING</h4>
                    <div class="sidebarContent">
                        <div class="breakingItem">
                            <strong><a href="javascript:navigateToArticle('MHH-018')">Tavern brawl: 5 hospitalized on Z-Level 28</a></strong>
                        </div>
                        <div class="breakingItem">
                            <strong><a href="javascript:navigateToArticle('MHH-019')">Steelthunder seeks injunction against Koganusan excavation</a></strong>
                        </div>
                        <div class="breakingItem">
                            <strong><a href="javascript:navigateToArticle('MHH-016')">Surface Relations Act passes 2nd reading, 6-3</a></strong>
                        </div>
                    </div>
