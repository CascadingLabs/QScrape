---
import AdUnit from './_components/AdUnit.astro';
import HeraldShell from './_components/HeraldShell.astro';
import {
	articles,
	categories,
	formatDate,
	formatDateTime,
} from './_data/articles';

const sorted = [...articles].sort(
	(a, b) => new Date(b.published).getTime() - new Date(a.published).getTime(),
);
---

<HeraldShell title="Article Archive" activePage="articles" breadcrumbs={[{ label: 'Home', href: '/l1/news/' }, { label: 'Articles' }]}>

  <div class="pageTitle">Article Archive</div>

  <div class="searchBox">
    <table border="0" cellpadding="3" cellspacing="0" style="width:100%;">
      <tr>
        <td align="right" style="width:25%;"><strong>Keyword:</strong></td>
        <td><input type="text" id="txtKeyword" style="width:200px;" placeholder="Search headline or excerpt" /></td>
      </tr>
      <tr>
        <td align="right"><strong>Category:</strong></td>
        <td>
          <select id="ddlCategory" style="width:206px;">
            <option value="">(All Categories)</option>
            {categories.map(c => <option value={c}>{c}</option>)}
          </select>
        </td>
      </tr>
      <tr>
        <td align="right"><strong>Date From:</strong></td>
        <td><input type="text" id="txtDateFrom" placeholder="MM/DD/YYYY" style="width:120px;" /></td>
      </tr>
      <tr>
        <td align="right"><strong>Date To:</strong></td>
        <td><input type="text" id="txtDateTo" placeholder="MM/DD/YYYY" style="width:120px;" /></td>
      </tr>
      <tr>
        <td>&nbsp;</td>
        <td><input type="submit" value="Search Articles" id="btnSearch" onclick="applyFilters(); return false;" /></td>
      </tr>
    </table>
  </div>

  <div class="resultsInfo" id="resultsInfo">Showing {sorted.length} article(s)</div>

  <table class="grid-view" cellspacing="0" rules="all" border="1" id="articlesGrid" style="border-collapse:collapse;">
    <tr>
      <th scope="col" style="width:130px;">Published</th>
      <th scope="col" style="width:80px;">Category</th>
      <th scope="col">Headline</th>
      <th scope="col" style="width:130px;">Author</th>
      <th scope="col" style="width:50px;">Read</th>
    </tr>
    {sorted.map((a, i) => (
      <tr
        style={i % 2 === 1 ? 'background-color:#E3EAEB;' : ''}
        data-id={a.id}
        data-excerpt={a.excerpt}
        data-published={a.published}
      >
        <td>
          {formatDate(a.published)}
          <br/><span style="font-size:9px;color:#888;">{formatDateTime(a.published).split(' at ')[1]}</span>
          {a.updated && <br/>}
          {a.updated && <span style="font-size:9px;color:#cc0000;">Updated {formatDate(a.updated)}</span>}
        </td>
        <td><span class={`categoryBadge cat-${a.category}`}>{a.category}</span></td>
        <td data-excerpt={a.headline + ' ' + a.excerpt}>{a.headline}</td>
        <td>{a.author}</td>
        <td><a href="javascript:void(0)" onclick={`navigateToArticle('${a.id}')`}>Read</a></td>
      </tr>
    ))}
  </table>

  <!-- Inline ad in listing -->
  <div class="adSlot--inline" style="margin:12px 0;">
    <AdUnit size="leaderboard" adId="DSN-LB-006" text="Stonecleave &amp; Gemcutter LLP &mdash; Fortress Law Specialists" cta="Free Consultation" placement="articles_inline" />
  </div>

  <table style="margin:15px;">
    <tr>
      <td id="gridPager">
        <span class="aspNetLabel">Page 1 of 2</span>&nbsp;&nbsp;<span style="font-weight:bold;">[1]</span>&nbsp;<a href="javascript:__doPageChange(2)">2</a>
      </td>
    </tr>
  </table>

  <script is:inline>
  var PAGE_SIZE = 10;
  var currentPage = 1;
  var filteredRows = [];

  function parseDate(str) {
    var parts = str.trim().split('/');
    if (parts.length !== 3) return null;
    var d = new Date(parseInt(parts[2]), parseInt(parts[0]) - 1, parseInt(parts[1]));
    return isNaN(d.getTime()) ? null : d;
  }

  function applyFilters() {
    var keyword  = document.getElementById('txtKeyword').value.trim().toLowerCase();
    var category = document.getElementById('ddlCategory').value;
    var dateFrom = parseDate(document.getElementById('txtDateFrom').value);
    var dateTo   = parseDate(document.getElementById('txtDateTo').value);

    var allRows = Array.prototype.slice.call(
      document.querySelectorAll('#articlesGrid tr:not(:first-child)')
    );

    filteredRows = allRows.filter(function(row) {
      var cells = row.querySelectorAll('td');
      var rowDateStr = cells[0] ? cells[0].textContent.trim().split('\n')[0] : '';
      var rowDate = parseDate(rowDateStr);
      var rowCategory = cells[1] ? cells[1].textContent.trim() : '';
      var headlineTd  = cells[2];
      var searchText = headlineTd ? (headlineTd.getAttribute('data-excerpt') || headlineTd.textContent).toLowerCase() : '';

      return (!keyword  || searchText.indexOf(keyword) !== -1)
          && (!category || rowCategory === category)
          && (!dateFrom || (rowDate && rowDate >= dateFrom))
          && (!dateTo   || (rowDate && rowDate <= dateTo));
    });

    currentPage = 1;
    renderPage();
  }

  function renderPage() {
    var allRows = Array.prototype.slice.call(
      document.querySelectorAll('#articlesGrid tr:not(:first-child)')
    );
    allRows.forEach(function(r) { r.style.display = 'none'; });

    var start = (currentPage - 1) * PAGE_SIZE;
    filteredRows.slice(start, start + PAGE_SIZE).forEach(function(r) { r.style.display = ''; });

    document.getElementById('resultsInfo').textContent =
      'Showing ' + filteredRows.length + ' article(s)';
    renderPager();
  }

  function renderPager() {
    var totalPages = Math.max(1, Math.ceil(filteredRows.length / PAGE_SIZE));
    var pager = document.getElementById('gridPager');
    var html = '<span class="aspNetLabel">Page ' + currentPage + ' of ' + totalPages + '</span>&nbsp;&nbsp;';
    for (var i = 1; i <= totalPages; i++) {
      if (i === currentPage) {
        html += '<span style="font-weight:bold;">[' + i + ']</span>&nbsp;';
      } else {
        html += '<a href="javascript:__doPageChange(' + i + ')">' + i + '</a>&nbsp;';
      }
    }
    pager.innerHTML = html;
  }

  function __doPageChange(page) {
    currentPage = page;
    renderPage();
  }

  window.addEventListener('load', function() { applyFilters(); });
  </script>
</HeraldShell>
