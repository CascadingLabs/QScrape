---
import AdUnit from './AdUnit.astro';
import { getBreaking, formatDateTime } from '../_data/articles';

interface Props {
  title: string;
  activePage?: 'home' | 'articles' | 'about' | 'staff' | 'contact';
  breadcrumbs?: Array<{ label: string; href?: string }>;
  showAds?: boolean;
}

const {
  title,
  activePage = 'home',
  breadcrumbs = [],
  showAds = true,
} = Astro.props;

const breakingArticles = getBreaking();
const lastUpdated = formatDateTime('2026-03-11T20:15:00');

const leaderboardAds = [
  { adId: 'DSN-LB-001', text: 'Mountainhome Ale Guild \u2014 Finest Plump Helmet Ale Since Year 89', cta: 'Order Now', placement: 'header_leaderboard' },
  { adId: 'DSN-LB-002', text: 'Registry of Deeds \u2014 Search Deeds, Mortgages & Liens Online', cta: 'Search Records', placement: 'header_leaderboard' },
  { adId: 'DSN-LB-003', text: 'Headshoots LLC \u2014 Siege Equipment Specialists Since Year 270', cta: 'View Catalog', placement: 'header_leaderboard' },
];
const footerAds = [
  { adId: 'DSN-LB-004', text: 'Bureau of Surface Commerce \u2014 Trade Permits & Route Information', cta: 'Apply Today', placement: 'footer_leaderboard' },
  { adId: 'DSN-LB-005', text: 'Dwarven Iron Guild \u2014 Quality Forgework at Fair Prices', cta: 'Find a Smith', placement: 'footer_leaderboard' },
];

const headerAd = leaderboardAds[Math.floor(Math.random() * leaderboardAds.length)];
const footerAd = footerAds[Math.floor(Math.random() * footerAds.length)];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - Mountainhome Herald</title>
  <link rel="stylesheet" href="/global.css">
  <link rel="alternate" type="application/rss+xml" title="Mountainhome Herald — All Stories" href="/l1/news/rss/all.xml">
</head>
<body>
  <div id="container">
    <!-- Header -->
    <div class="headerBar">
      MOUNTAINHOME HERALD
      <span class="headerMeta">Last Updated: {lastUpdated}</span>
    </div>

    <!-- Breaking Ticker -->
    {breakingArticles.length > 0 && (
      <div class="newsTicker">
        <span class="tickerLabel">BREAKING</span>
        <div class="tickerTrack">
          {breakingArticles.map((a, i) => (
            <span class="tickerItem">
              <a href={`javascript:void(0)`} data-article-id={a.id} class="tickerLink">{a.headline}</a>
              {i < breakingArticles.length - 1 && <span class="tickerSep">&bull;</span>}
            </span>
          ))}
          {/* duplicate for seamless scroll */}
          {breakingArticles.map((a, i) => (
            <span class="tickerItem">
              <a href={`javascript:void(0)`} data-article-id={a.id} class="tickerLink">{a.headline}</a>
              {i < breakingArticles.length - 1 && <span class="tickerSep">&bull;</span>}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Nav -->
    <div class="navBar">
      <a href="/l1/news/" class={activePage === 'home' ? 'active' : ''}>Home</a>
      <a href="/l1/news/articles" class={activePage === 'articles' ? 'active' : ''}>Articles</a>
      <a href="/l1/news/about" class={activePage === 'about' ? 'active' : ''}>About</a>
      <a href="/l1/news/staff" class={activePage === 'staff' ? 'active' : ''}>Staff</a>
      <a href="/l1/news/contact" class={activePage === 'contact' ? 'active' : ''}>Contact</a>
      <a href="/l1/news/rss/" class="rssLink" style="color:#ff6600;">RSS</a>
      <span class="navSep">|</span>
      <a href="/l1/taxes/">ROD Records</a>
      <a href="/l1/scoretap/">ScoreTap</a>
    </div>

    <!-- Leaderboard Ad -->
    {showAds && (
      <div class="adSlot adSlot--leaderboard">
        <AdUnit size="leaderboard" adId={headerAd.adId} text={headerAd.text} cta={headerAd.cta} placement={headerAd.placement} campaign="DSN-CAM-2026-Q1" />
      </div>
    )}

    <!-- Breadcrumbs -->
    {breadcrumbs.length > 0 && (
      <div class="breadcrumbs">
        {breadcrumbs.map((bc, i) => (
          <>
            {i > 0 && <span> &gt; </span>}
            {bc.href ? <a href={bc.href}>{bc.label}</a> : <span>{bc.label}</span>}
          </>
        ))}
      </div>
    )}

    <!-- Page Content -->
    <slot />

    <!-- Footer Ad -->
    {showAds && (
      <div class="adSlot adSlot--footer">
        <AdUnit size="leaderboard" adId={footerAd.adId} text={footerAd.text} cta={footerAd.cta} placement={footerAd.placement} campaign="DSN-CAM-2026-Q1" />
      </div>
    )}

    <!-- Footer -->
    <div class="footerBar">
      &copy; 2026 Mountainhome Herald | MHH CMS v1.0.2004 |
      <a href="/l1/news/about" style="color:#99bbdd;">About</a> |
      <a href="/l1/news/staff" style="color:#99bbdd;">Staff</a> |
      <a href="/l1/news/contact" style="color:#99bbdd;">Contact</a> |
      <a href="/l1/taxes/" style="color:#99bbdd;">ROD Records</a> |
      <a href="/l1/news/rss/" style="color:#ff6600;">RSS Feeds</a>
    </div>
  </div>

  <!-- Shared article navigation script -->
  <script is:inline>
  function navigateToArticle(id) {
    var hash = Math.random().toString(36).substring(2,15);
    var payload = 'MHH_v1_Kp9rXm2bQs' +
                  'XXXNNNXXX' +
                  'ID=' + encodeURIComponent(id) + '&HASH=' + hash +
                  'XXXNNNXXX' +
                  'tR7vYw1hF3dG' +
                  'XXXNNNXXX';
    window.location.href = '/l1/news/article?postData=' + encodeURIComponent(payload);
  }

  // Wire up ticker links
  document.querySelectorAll('.tickerLink[data-article-id]').forEach(function(el) {
    el.addEventListener('click', function(e) {
      e.preventDefault();
      navigateToArticle(el.getAttribute('data-article-id'));
    });
  });

  // Relative time helper
  function timeAgo(iso) {
    var ms = new Date('2026-03-11T21:00:00').getTime() - new Date(iso).getTime();
    var mins = Math.floor(ms / 60000);
    if (mins < 1) return 'just now';
    if (mins < 60) return mins + 'm ago';
    var hours = Math.floor(mins / 60);
    if (hours < 24) return hours + 'h ago';
    var days = Math.floor(hours / 24);
    if (days === 1) return 'yesterday';
    if (days < 7) return days + 'd ago';
    var weeks = Math.floor(days / 7);
    return weeks + 'w ago';
  }

  // Update any elements with data-time-ago
  document.querySelectorAll('[data-time-ago]').forEach(function(el) {
    el.textContent = timeAgo(el.getAttribute('data-time-ago'));
  });
  </script>
</body>
</html>

<style is:global>
  /* ═══════════════════════════════════════════════════
     HERALD SHELL — Shared Styles
     ═══════════════════════════════════════════════════ */

  .headerMeta {
    float: right;
    font-size: 11px;
    font-weight: normal;
  }

  /* News Ticker */
  .newsTicker {
    background: #1a1a2e;
    color: #ffffff;
    font-size: 11px;
    display: block;
    overflow: hidden;
    height: 24px;
    max-height: 24px;
    position: relative;
    white-space: nowrap;
    line-height: 24px;
  }
  .tickerLabel {
    background: #cc0000;
    color: #ffffff;
    font-weight: bold;
    font-size: 10px;
    padding: 4px 8px;
    letter-spacing: 1px;
    display: inline-block;
    vertical-align: top;
    line-height: 16px;
    z-index: 1;
    position: relative;
  }
  .tickerTrack {
    display: inline-block;
    white-space: nowrap;
    animation: tickerScroll 30s linear infinite;
    padding-left: 12px;
  }
  .tickerItem { margin-right: 8px; white-space: nowrap; }
  .tickerLink { color: #ffdd44; text-decoration: none; white-space: nowrap; }
  .tickerLink:hover { text-decoration: underline; }
  .tickerSep { color: #666; margin: 0 8px; }
  @keyframes tickerScroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Nav active state */
  .navBar a.active {
    background-color: #003366;
    color: #ffffff;
  }
  .navSep {
    color: #999;
    margin: 0 2px;
    font-size: 10px;
  }

  /* Ad slots */
  .adSlot { text-align: center; margin: 0; padding: 6px 0; background: #f8f8f8; border-bottom: 1px solid #ddd; }
  .adSlot--footer { border-top: 1px solid #ddd; border-bottom: none; margin-top: 10px; }

  /* ─── Category Badges ─── */
  .categoryBadge { padding: 2px 6px; font-size: 10px; font-weight: bold; white-space: nowrap; }
  .cat-Politics  { background-color: #bee3f8; color: #2a4365; }
  .cat-Crime     { background-color: #feebc8; color: #744210; }
  .cat-Economy   { background-color: #c6f6d5; color: #22543d; }
  .cat-Culture   { background-color: #e9d8fd; color: #44337a; }
  .cat-Sports    { background-color: #c6f6d5; color: #22543d; }
  .cat-Weather   { background-color: #feebc8; color: #744210; }

  /* ─── Category Strip ─── */
  .categoryStrip { background-color: #ece9d8; padding: 4px 15px; border-bottom: 2px solid #003366; }
  .categoryStrip a {
    color: #003366; text-decoration: none; margin-right: 12px;
    padding: 2px 6px; font-weight: bold; font-size: 11px;
  }
  .categoryStrip a:hover, .categoryStrip a.active { background-color: #003366; color: #ffffff; }

  /* ─── Article Cards ─── */
  .articleCard {
    border-bottom: 1px solid #cccccc;
    padding: 8px;
    overflow: hidden;
  }
  .articleCard .cardMeta { color: #666666; font-size: 10px; margin-bottom: 3px; }
  .articleCard a.cardHeadline {
    color: #003366; text-decoration: none; font-weight: bold; font-size: 12px;
    display: block; margin-bottom: 3px;
  }
  .articleCard a.cardHeadline:hover { text-decoration: underline; }
  .cardExcerpt { font-size: 11px; color: #333; line-height: 1.4; }
  .cardThumb {
    float: right; width: 80px; height: 55px; object-fit: cover;
    margin: 0 0 4px 8px; border: 1px solid #ccc;
  }
  .cardTimeAgo { color: #999; font-size: 9px; font-style: italic; }

  /* ─── Two-Column Layout ─── */
  .twoCol { overflow: hidden; }
  .mainCol { float: left; width: 580px; }
  .sidebarCol { float: right; width: 190px; }
  .clearfix::after { content: ""; display: table; clear: both; }

  /* ─── Featured Box ─── */
  .featuredBox {
    border: 2px solid #003366; margin: 10px 10px 10px 15px; padding: 0;
    background-color: #f0f0f0; overflow: hidden;
  }
  .featuredLabel {
    background-color: #cc0000; color: #ffffff; font-size: 10px;
    font-weight: bold; padding: 2px 6px; display: inline-block;
  }
  .featuredContent { padding: 10px; }
  .featuredBox h2 { font-size: 14px; margin: 4px 0 6px 0; }
  .featuredBox h2 a { color: #003366; text-decoration: none; }
  .featuredBox h2 a:hover { text-decoration: underline; }
  .featuredBox p { font-size: 11px; margin: 4px 0; line-height: 1.5; }
  .featuredImg { width: 100%; height: auto; display: block; }
  .featuredImgCaption {
    font-size: 9px; color: #666; font-style: italic;
    padding: 3px 10px; background: #e8e8e8; border-bottom: 1px solid #ccc;
  }

  /* ─── Section Boxes ─── */
  .topStoriesBox { margin: 10px 10px 10px 15px; }
  .topStoriesBox h3,
  .latestBox h3 {
    background-color: #003366; color: #ffffff; padding: 4px 8px;
    margin: 0; font-size: 12px;
  }
  .latestBox { margin: 10px 10px 10px 15px; }
  .latestBox ul { margin: 0; padding: 0; list-style: none; }
  .latestBox ul li {
    border-bottom: 1px solid #eeeeee; padding: 5px 8px; font-size: 11px;
    overflow: hidden;
  }
  .latestBox ul li a { color: #003366; text-decoration: none; }
  .latestBox ul li a:hover { text-decoration: underline; }

  /* ─── Sidebar ─── */
  .sidebarBox { border: 1px solid #999999; margin: 10px 15px 10px 5px; }
  .sidebarBox h4 {
    background-color: #cc0000; color: #ffffff; padding: 4px 8px;
    margin: 0; font-size: 11px; font-weight: bold;
  }
  .sidebarBox .sidebarContent { padding: 6px 8px; font-size: 10px; line-height: 1.5; }
  .sidebarBox .sidebarContent a { color: #003366; font-weight: bold; }
  .sidebarImg { width: 100%; height: auto; display: block; border-bottom: 1px solid #ccc; }
  .breakingItem { border-bottom: 1px solid #eeeeee; padding: 4px 0; }
  .breakingItem:last-child { border-bottom: none; }
  .catCount { display: flex; justify-content: space-between; border-bottom: 1px solid #eeeeee; padding: 3px 0; }
  .catCount:last-child { border-bottom: none; }

  /* ─── Article Detail ─── */
  .articleMeta td { padding: 5px 10px; border: 1px solid #cccccc; }
  .articleMeta tr:nth-child(even) { background-color: #f9f9f9; }
  .articleBody { margin: 15px; line-height: 1.7; font-size: 12px; }
  .articleBody p { margin: 10px 0; }
  .articleImage { margin: 15px; border: 1px solid #999999; background: #f0f0f0; padding: 4px; }
  .articleImage img { display: block; width: 100%; height: auto; }
  .articleImage .imageCaption {
    font-size: 10px; color: #666666; padding: 4px 2px 2px 2px;
    font-style: italic; border-top: 1px solid #cccccc; margin-top: 4px;
  }
  .articleImage .imageCredit { font-size: 9px; color: #999999; float: right; }
  .relatedLinks { margin: 15px; }
  .relatedLinks a { display: block; margin: 4px 0; }
  .tagList span { background: #ece9d8; border: 1px solid #999; padding: 1px 6px; margin-right: 4px; font-size: 10px; }

  /* ─── Pull Quotes & Info Boxes ─── */
  .pullQuote {
    border-left: 3px solid #cc0000; margin: 12px 20px; padding: 8px 12px;
    font-style: italic; font-size: 12px; background: #f9f9f9; color: #333;
  }
  .pullQuote .attribution {
    font-style: normal; font-size: 10px; color: #666; margin-top: 4px; display: block;
  }
  .infoBox {
    border: 1px solid #003366; margin: 12px 15px; padding: 0;
    background: #f0f4f8; font-size: 11px;
  }
  .infoBox .infoTitle {
    background: #003366; color: #fff; padding: 4px 8px;
    font-weight: bold; font-size: 10px;
  }
  .infoBox .infoContent { padding: 8px; line-height: 1.5; }
  .infoBox .infoContent a { color: #003366; }

  /* ─── Inline Ad ─── */
  .adSlot--inline { margin: 12px 15px; text-align: center; background: #f8f8f8; padding: 6px 0; border: 1px solid #eee; }

  /* ─── Comments ─── */
  .commentItem {
    border-bottom: 1px solid #ddd; padding: 8px 0; font-size: 11px;
  }
  .commentItem:last-child { border-bottom: none; }
  .commentHeader { margin-bottom: 3px; }
  .commentDate { color: #999; font-size: 9px; margin-left: 6px; }
  .commentBody { line-height: 1.5; color: #333; }
  .commentReply {
    margin: 6px 0 4px 20px; padding: 6px 8px;
    border-left: 2px solid #cc0000; background: #f9f9f9;
    font-size: 11px;
  }

  /* ─── Weather Widget ─── */
  .weatherWidget { font-size: 10px; line-height: 1.6; }
  .weatherWidget table { width: 100%; border-collapse: collapse; }
  .weatherWidget th {
    background: #1a1a2e; color: #ffdd44; font-size: 9px;
    padding: 2px 4px; text-align: left;
  }
  .weatherWidget td {
    padding: 2px 4px; border-bottom: 1px solid #eee; font-size: 10px;
  }
  .weatherWidget .wxStable { color: #228B22; font-weight: bold; }
  .weatherWidget .wxCaution { color: #CC8800; font-weight: bold; }
  .weatherWidget .wxAlert { color: #CC0000; font-weight: bold; }
  .weatherWidget .wxUpdate {
    font-size: 8px; color: #999; font-style: italic;
    margin-top: 4px; text-align: right;
  }
</style>
