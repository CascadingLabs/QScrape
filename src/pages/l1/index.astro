<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>L1 — QScrape</title>
        <link rel="stylesheet" href="/qscrape.css" />
    </head>
    <body>
        <div class="container">
            <header>
                <div class="breadcrumb">
                    <a href="/">QScrape</a> / L1
                </div>
                <div class="logo">Level 1</div>
                <div class="tagline">
                    Standard HTML/CSS/JS — no dynamic data, no web frameworks
                </div>
            </header>

            <section>
                <h2>About</h2>
                <p>
                    L1 sites are static pages built with <a
                        href="https://astro.build/"
                        target="_blank"
                        rel="noopener">Astro</a
                    >. All content is rendered at build time into plain HTML.
                    There are no client-side frameworks, no API calls, and no
                    anti-scraping measures. These sites serve as a baseline to
                    verify that a scraper can correctly parse real-world HTML
                    structure, navigate multi-page sites, and extract structured
                    data.
                </p>
            </section>

            <section>
                <h2>Sites</h2>
                <ul class="card-list">
                    <li>
                        <a class="card-item" href="/l1/news/">
                            <div class="card-header">
                                <span class="card-label">/l1/news</span>
                                <span class="badge-live">LIVE</span>
                                <span class="card-arrow">↗</span>
                            </div>
                            <div class="card-name">Mountainhome Herald</div>
                            <div class="card-desc">
                                News portal with article listings, individual
                                articles, and a rss feeds. Tests pagination and
                                article extraction.
                            </div>
                        </a>
                    </li>
                    <li>
                        <a class="card-item" href="/l1/scoretap/">
                            <div class="card-header">
                                <span class="card-label">/l1/scoretap</span>
                                <span class="badge-live">LIVE</span>
                                <span class="card-arrow">↗</span>
                            </div>
                            <div class="card-name">ScoreTap</div>
                            <div class="card-desc">
                                Esports scores and match results. Tests
                                structured tabular data, team/event
                                relationships, and linked detail pages.
                            </div>
                        </a>
                    </li>
                    <li>
                        <a class="card-item" href="/l1/taxes/">
                            <div class="card-header">
                                <span class="card-label">/l1/taxes</span>
                                <span class="badge-live">LIVE</span>
                                <span class="card-arrow">↗</span>
                            </div>
                            <div class="card-name">
                                Eldoria Registry of Deeds
                            </div>
                            <div class="card-desc">
                                Property tax records and deed search. Tests
                                form-like search interfaces, record listings,
                                and document viewer pages.
                            </div>
                        </a>
                    </li>
                </ul>
            </section>
        </div>
    </body>
</html>
