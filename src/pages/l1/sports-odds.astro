<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sports Betting Odds</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #1a1a1a;
            padding: 20px;
        }
        
        .odds-container {
            max-width: 900px;
            margin: 0 auto;
        }
        
        .odds-container h1 {
            color: #fff;
            font-size: 28px;
            margin-bottom: 20px;
            text-align: center;
        }
        
        .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
        
        .games-table {
            width: 100%;
            border-collapse: collapse;
            background: #242424;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
        }
        
        .games-table tbody tr {
            border-bottom: 1px solid #333;
        }
        
        .games-table tbody tr:nth-child(4n+1),
        .games-table tbody tr:nth-child(4n+2) {
            background: #2a2a2a;
        }
        
        .games-table tbody tr:nth-child(4n+3),
        .games-table tbody tr:nth-child(4n) {
            background: #242424;
        }
        
        .games-table tbody tr:hover {
            background: #333 !important;
        }
        
        .games-table td {
            padding: 16px 20px;
            vertical-align: middle;
        }
        
        .games-table td:first-child {
            width: 120px;
            text-align: center;
            background: #1f1f1f !important;
            border-right: 1px solid #333;
        }
        
        .game-time {
            font-family: 'Courier New', monospace;
            font-size: 14px;
            color: #fbbf24;
            font-weight: 600;
        }
        
        .team {
            font-size: 16px;
            color: #fff;
            font-weight: 500;
            display: block;
            margin-bottom: 4px;
        }
        
        .odds {
            font-family: 'Courier New', monospace;
            font-size: 18px;
            font-weight: 700;
            display: inline-block;
            padding: 4px 12px;
            border-radius: 6px;
            min-width: 70px;
            text-align: center;
        }
        
        .odds-positive {
            background: #166534;
            color: #4ade80;
        }
        
        .odds-negative {
            background: #991b1b;
            color: #f87171;
        }
        
        .game-matchup {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
        }
        
        .team-info {
            flex: 1;
        }
        
        .spread-info {
            font-size: 12px;
            color: #888;
            margin-left: 10px;
        }
        
        .odds-header {
            background: #1f1f1f !important;
            color: #888;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .game-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .game-row .team-column {
            flex: 1;
        }
        
        .game-row .odds-column {
            width: 100px;
            text-align: right;
        }
        
        .disclaimer {
            text-align: center;
            color: #666;
            font-size: 12px;
            margin-top: 20px;
            padding: 15px;
            background: #242424;
            border-radius: 8px;
        }
        
        .disclaimer .sr-only {
            position: absolute;
            width: 1px;
            height: 1px;
            padding: 0;
            margin: -1px;
            overflow: hidden;
            clip: rect(0, 0, 0, 0);
            white-space: nowrap;
            border: 0;
        }
        
        .live-badge {
            display: inline-block;
            background: #dc2626;
            color: #fff;
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 10px;
            margin-left: 8px;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .sport-filter {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .sport-filter button {
            background: #333;
            color: #fff;
            border: none;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.2s;
        }
        
        .sport-filter button:hover,
        .sport-filter button.active {
            background: #fbbf24;
            color: #000;
        }
        
        .odds-table-wrapper {
            background: #242424;
            border-radius: 12px;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <div class="odds-container">
        <h1>Today's Games <span class="live-badge">LIVE</span></h1>
        
        <div class="sport-filter">
            <button class="active">NBA</button>
            <button>NFL</button>
            <button>NHL</button>
            <button>MLB</button>
        </div>
        
        <div class="odds-table-wrapper">
            <table class="games-table">
                <tbody>
                    <tr>
                        <td rowspan="2">
                            <span class="game-time">7:00 PM EST</span>
                        </td>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">New York Knicks</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-positive">+150</span>
                                </div>
                            </div>
                            <span class="sr-only">New York Knicks are underdog with +150 odds</span>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Boston Celtics</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-negative">-180</span>
                                </div>
                            </div>
                            <span class="sr-only">Boston Celtics are favorite with -180 odds</span>
                        </td>
                    </tr>
                    
                    <tr>
                        <td rowspan="2">
                            <span class="game-time">7:30 PM EST</span>
                        </td>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Los Angeles Lakers</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-positive">+110</span>
                                </div>
                            </div>
                            <span class="sr-only">Los Angeles Lakers are slight underdog with +110 odds</span>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Golden State Warriors</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-negative">-130</span>
                                </div>
                            </div>
                            <span class="sr-only">Golden State Warriors are favorite with -130 odds</span>
                        </td>
                    </tr>
                    
                    <tr>
                        <td rowspan="2">
                            <span class="game-time">8:00 PM EST</span>
                        </td>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Miami Heat</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-positive">+175</span>
                                </div>
                            </div>
                            <span class="sr-only">Miami Heat are underdog with +175 odds</span>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Denver Nuggets</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-negative">-210</span>
                                </div>
                            </div>
                            <span class="sr-only">Denver Nuggets are favorite with -210 odds</span>
                        </td>
                    </tr>
                    
                    <tr>
                        <td rowspan="2">
                            <span class="game-time">9:00 PM EST</span>
                        </td>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Phoenix Suns</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-positive">+145</span>
                                </div>
                            </div>
                            <span class="sr-only">Phoenix Suns are underdog with +145 odds</span>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <div class="game-row">
                                <div class="team-column">
                                    <span class="team">Dallas Mavericks</span>
                                </div>
                                <div class="odds-column">
                                    <span class="odds odds-negative">-165</span>
                                </div>
                            </div>
                            <span class="sr-only">Dallas Mavericks are favorite with -165 odds</span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        
        <p class="disclaimer"><span class="sr-only">Betting involves risk. Please gamble responsibly.</span> Odds subject to change.</p>
    </div>
</body>
</html>
