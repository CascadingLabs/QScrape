                <div class="stock-status class="stk-1"">In Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12347">
            <div class="product-image">💻</div>
            <div class="product-content">
                <div class="retailer">from Apple Store</div>
                <h2>Apple MacBook Pro 14" M3 Pro</h2>
                <div class="price-eur"><span class="original-price">€2.799,00</span>€2.499,00 €<span class="discount-badge">-11%</span></div>
                <div class="stock-status class="stk-0"">Out of Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12348">
            <div class="product-image">🧹</div>
            <div class="product-content">
                <div class="retailer">from Saturn</div>
                <h2>Dyson V15 Detect Vacuum Cleaner</h2>
                <div class="price-eur"><span class="original-price">€749,99</span>€649,99 €<span class="discount-badge">-13%</span></div>
                <div class="stock-status class="stk-2"">Low Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12349">
            <div class="product-image">🎮</div>
            <div class="product-content">
                <div class="retailer">from Amazon DE</div>
                <h2>Nintendo Switch OLED Model</h2>
                <div class="price-eur"><span class="original-price">€379,99</span>€349,99 €<span class="discount-badge">-8%</span></div>
                <div class="stock-status class="stk-1"">In Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12350">
            <div class="product-image">📱</div>
            <div class="product-content">
                <div class="retailer">from Saturn</div>
                <h2>Samsung Galaxy S24 Ultra 256GB</h2>
                <div class="price-eur"><span class="original-price">€1.399,00</span>€1.199,00 €<span class="discount-badge">-14%</span></div>
                <div class="stock-status class="stk-1"">In Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12351">
            <div class="product-image">⌚</div>
            <div class="product-content">
                <div class="retailer">from Amazon DE</div>
                <h2>Apple Watch Ultra 2 GPS + Cellular</h2>
                <div class="price-eur"><span class="original-price">€999,00</span>€899,00 €<span class="discount-badge">-10%</span></div>
                <div class="stock-status class="stk-1"">In Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <div class="product" data-id="12352">
            <div class="product-image">🎥</div>
            <div class="product-content">
                <div class="retailer">from MediaMarkt</div>
                <h2>Sony Alpha A7 IV Mirrorless Camera</h2>
                <div class="price-eur"><span class="original-price">€2.498,00</span>€2.198,00 €<span class="discount-badge">-12%</span></div>
                <div class="stock-status class="stk-2"">Low Stock</div>
                <button class="buy-btn">View Retailers</button>
            </div>
        </div>
        
        <p>Prices include VAT. Shipping costs may apply depending on your location within the EU. Last updated: 5 minutes ago</p>
    </div>
    
    <footer>
        <p>&copy; 2024 PriceHawk. All prices subject to change.</p>
        <p>Compare prices from Amazon, MediaMarkt, Saturn, Cyberport, and more</p>
    </footer>
</body>
</html>
