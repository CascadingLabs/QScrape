<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Price Compare - Electronics</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f8f9fa;
            padding: 20px;
        }
        
        .product-listing h1 {
            text-align: center;
            color: #1a1a1a;
            margin-bottom: 40px;
            font-size: 2rem;
        }
        
        .product-listing {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        .product {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            transition: transform 0.2s, box-shadow 0.2s;
            border: 1px solid #e9ecef;
        }
        
        .product:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        }
        
        .product h2 {
            font-size: 1.1rem;
            color: #333;
            margin-bottom: 16px;
            line-height: 1.4;
            min-height: 50px;
        }
        
        .price-eur {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 12px;
        }
        
        .price-eur::before {
            content: 'Price: ';
            font-weight: 400;
            color: #666;
            font-size: 0.9rem;
        }
        
        .stock-status {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }
        
        .stock-status[class*="stk-1"] {
            background: #d4edda;
            color: #155724;
        }
        
        .stock-status[class*="stk-0"] {
            background: #f8d7da;
            color: #721c24;
        }
        
        .stock-status[class*="stk-2"] {
            background: #fff3cd;
            color: #856404;
        }
        
        .product-listing > p {
            grid-column: 1 / -1;
            text-align: center;
            color: #666;
            margin-top: 30px;
            font-size: 0.9rem;
        }
        
        .original-price {
            text-decoration: line-through;
            color: #999;
            font-size: 1rem;
            margin-right: 8px;
        }
        
        .discount-badge {
            background: #dc3545;
            color: #fff;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="product-listing">
        <h1>Latest Deals from Top Retailers</h1>
        
        <div class="product" data-id="12345">
            <h2>Sony WH-1000XM5 Wireless Headphones</h2>
            <div class="price-eur">€349,00</div>
            <div class="stock-status class="stk-0"">Out of Stock</div>
        </div>
        
        <div class="product" data-id="12346">
            <h2>Samsung 65" QLED 4K Smart TV</h2>
            <div class="price-eur">€1.200,50 €</div>
            <div class="stock-status class="stk-1"">In Stock</div>
        </div>
        
        <div class="product" data-id="12347">
            <h2>Apple MacBook Pro 14" M3</h2>
            <div class="price-eur">€2.499,00 €</div>
            <div class="stock-status class="stk-0"">Out of Stock</div>
        </div>
        
        <div class="product" data-id="12348">
            <h2>Dyson V15 Detect Vacuum</h2>
            <div class="price-eur">€649,99 €</div>
            <div class="stock-status class="stk-2"">Low Stock</div>
        </div>
        
        <div class="product" data-id="12349">
            <h2>Nintendo Switch OLED</h2>
            <div class="price-eur">€349,99 €</div>
            <div class="stock-status class="stk-1"">In Stock</div>
        </div>
        
        <p>Prices include VAT. Shipping costs may apply depending on your location within the EU.</p>
    </div>
</body>
</html>
