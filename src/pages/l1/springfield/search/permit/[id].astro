---
export function getStaticPaths() {
    return [
        { params: { id: 'BLD-2024-001' } },
        { params: { id: 'BLD-2024-002' } },
        { params: { id: 'BLD-2024-003' } },
        { params: { id: 'BLD-2024-004' } },
        { params: { id: 'BLD-2024-005' } },
    ];
}

const { id } = Astro.params;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permit {id} - Springfield Municipal Permit Portal</title>
    <style>
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background: #f4f4f4;
            color: #333;
        }
        header {
            background: #1a365d;
            color: white;
            padding: 1rem 2rem;
        }
        header h1 { margin: 0; font-size: 1.5rem; }
        
        nav {
            background: #2c5282;
            padding: 0.75rem 2rem;
            display: flex;
            gap: 2rem;
        }
        nav a { color: white; text-decoration: none; font-weight: 500; }
        nav a:hover { text-decoration: underline; }
        
        .breadcrumbs {
            padding: 0.75rem 2rem;
            background: #e2e8f0;
            font-size: 0.875rem;
        }
        .breadcrumbs a { color: #2c5282; }
        
        main {
            max-width: 1000px;
            margin: 2rem auto;
            padding: 0 1rem;
        }
        
        .permit-info {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 2rem;
        }
        
        .permit-info h2 {
            color: #1a365d;
            margin-top: 0;
        }
        
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }
        
        .info-item {
            padding: 0.75rem;
            background: #f7fafc;
            border-radius: 4px;
        }
        
        .info-item label {
            display: block;
            font-size: 0.75rem;
            color: #718096;
            text-transform: uppercase;
            margin-bottom: 0.25rem;
        }
        
        .info-item span {
            font-weight: 600;
            color: #2d3748;
        }
        
        .document-container {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }
        
        .document-container h3 {
            color: #1a365d;
            margin-top: 0;
        }
        
        .pdf-link {
            display: inline-block;
            background: #e53e3e;
            color: white;
            padding: 0.75rem 1.5rem;
            border-radius: 4px;
            text-decoration: none;
            margin-bottom: 1rem;
        }
        
        .pdf-link:hover {
            background: #c53030;
        }
        
        .iframe-container {
            width: 100%;
            height: 600px;
            border: 1px solid #e2e8f0;
            border-radius: 4px;
            overflow: hidden;
        }
        
        .iframe-container iframe {
            width: 100%;
            height: 100%;
            border: none;
        }
        
        footer {
            background: #1a365d;
            color: white;
            padding: 2rem;
            text-align: center;
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header>
        <h1>Springfield Municipal Permit Portal</h1>
    </header>
    
    <nav>
        <a href="/l1/springfield/">Home</a>
        <a href="/l1/springfield/apply">Apply Online</a>
        <a href="/l1/springfield/search?id=12345">Permit Search</a>
        <a href="/l1/springfield/guides">Guides & Resources</a>
    </nav>
    
    <div class="breadcrumbs">
        <a href="/l1/springfield/">Home</a> &gt; 
        <a href="/l1/springfield/search?id=12345">Permit Search</a> &gt; 
        Permit Details
    </div>
    
    <main>
        <div class="permit-info">
            <h2>Permit #: {id}</h2>
            
            <div class="info-grid">
                <div class="info-item">
                    <label>Status</label>
                    <span>Approved</span>
                </div>
                <div class="info-item">
                    <label>Property Address</label>
                    <span>123 Main Street, Springfield, ST 12345</span>
                </div>
                <div class="info-item">
                    <label>Permit Type</label>
                    <span>Residential Addition</span>
                </div>
                <div class="info-item">
                    <label>Issue Date</label>
                    <span>January 15, 2024</span>
                </div>
                <div class="info-item">
                    <label>Expiration Date</label>
                    <span>January 15, 2025</span>
                </div>
                <div class="info-item">
                    <label>Estimated Cost</label>
                    <span>$45,000</span>
                </div>
            </div>
        </div>
        
        <div class="document-container">
            <h3>Permit Document</h3>
            
            <div class="download-section">
                <a href={`/documents/permits/${id}.pdf`} download class="pdf-link">
                    Download Permit_Summary.pdf
                </a>
            </div>

            <div class="viewer-section" style="margin-top: 2rem;">
                <iframe 
                    src={`/documents/viewer?file=${id}.pdf`} 
                    width="100%" 
                    height="600px" 
                    title="Permit Document Viewer">
                    <p>Your browser does not support iframes. Please download the PDF above.</p>
                </iframe>
            </div>
        </div>
    </main>
    
    <footer>
        <p>&copy; 2024 City of Springfield. All rights reserved.</p>
    </footer>
</body>
</html>
